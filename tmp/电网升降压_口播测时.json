  "segments": [
    {"id": "seg_001", "start": "00:00:00.500", "end": "00:00:08.000", "text": "电要低损耗地送到家，关键是：远距离先升压，靠近用户再多次降压。"},
    {"id": "seg_002", "start": "00:00:08.000", "end": "00:00:16.000", "text": "同样功率下，电压越高，电流越小；电流小，线路发热和传输损耗就越低。"},
    {"id": "seg_003", "start": "00:00:16.000", "end": "00:00:24.000", "text": "所以，发电厂旁的变压器先升压，再让高压线把电送到很远的城市。"},
    {"id": "seg_004", "start": "00:00:24.000", "end": "00:00:32.000", "text": "到城里，变电站先把电压降到配电网等级，并调节电能质量、隔离故障。"},
    {"id": "seg_005", "start": "00:00:32.000", "end": "00:00:40.000", "text": "接着，街边或小区的配电变压器再降一次，才到工厂、商场和家庭。"},
    {"id": "seg_006", "start": "00:00:40.000", "end": "00:00:48.000", "text": "这不是绕路：高压负责远送、少损耗；低压负责末端使用、更安全。"},
    {"id": "seg_007", "start": "00:00:48.000", "end": "00:00:56.000", "text": "交流电能方便地升降压，靠的是变压器两组线圈的电磁感应。你家附近的变压器在哪里？"}
  ]
}
