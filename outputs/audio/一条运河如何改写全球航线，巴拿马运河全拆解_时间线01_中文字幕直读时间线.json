{
  "version": 1,
  "source_subtitle": "一条运河如何改写全球航线，巴拿马运河全拆解_时间线01.srt",
  "output_audio": "一条运河如何改写全球航线，巴拿马运河全拆解_时间线01_中文字幕直读_Yunyang.mp3",
  "mode": "verbatim_chinese_subtitle_audio",
  "voice": "zh-CN-YunyangNeural",
  "rate": "+0%",
  "video_duration": "00:10:29.537",
  "segments": [
    {
      "id": "subtitle_001",
      "start": "00:00:00.233",
      "end": "00:00:01.866",
      "text": "巴拿马运河的目的"
    },
    {
      "id": "subtitle_002",
      "start": "00:00:01.866",
      "end": "00:00:03.833",
      "text": "很容易理解"
    },
    {
      "id": "subtitle_003",
      "start": "00:00:03.866",
      "end": "00:00:06.500",
      "text": "它把这段旅程变成了这样"
    },
    {
      "id": "subtitle_004",
      "start": "00:00:06.500",
      "end": "00:00:09.033",
      "text": "它使美国西海岸更接近欧洲"
    },
    {
      "id": "subtitle_005",
      "start": "00:00:09.033",
      "end": "00:00:11.700",
      "text": "它使美国东海岸更接近亚洲"
    },
    {
      "id": "subtitle_006",
      "start": "00:00:12.000",
      "end": "00:00:14.466",
      "text": "这些相当短的180英尺或"
    },
    {
      "id": "subtitle_007",
      "start": "00:00:14.666",
      "end": "00:00:16.800",
      "text": "55米宽的战壕组合在一起"
    },
    {
      "id": "subtitle_008",
      "start": "00:00:16.800",
      "end": "00:00:18.833",
      "text": "也许是最重要的"
    },
    {
      "id": "subtitle_009",
      "start": "00:00:18.833",
      "end": "00:00:20.400",
      "text": "和最有影响力的水道"
    },
    {
      "id": "subtitle_010",
      "start": "00:00:20.400",
      "end": "00:00:21.200",
      "text": "在地球上"
    },
    {
      "id": "subtitle_011",
      "start": "00:00:21.400",
      "end": "00:00:24.500",
      "text": "那是因为全世界的航运业"
    },
    {
      "id": "subtitle_012",
      "start": "00:00:24.500",
      "end": "00:00:26.866",
      "text": "是由巴拿马运河塑造的"
    },
    {
      "id": "subtitle_013",
      "start": "00:00:27.300",
      "end": "00:00:28.500",
      "text": "几百年前"
    },
    {
      "id": "subtitle_014",
      "start": "00:00:28.500",
      "end": "00:00:29.800",
      "text": "运河的机会"
    },
    {
      "id": "subtitle_015",
      "start": "00:00:29.800",
      "end": "00:00:31.700",
      "text": "横跨狭窄的巴拿马"
    },
    {
      "id": "subtitle_016",
      "start": "00:00:31.700",
      "end": "00:00:32.800",
      "text": "被识别"
    },
    {
      "id": "subtitle_017",
      "start": "00:00:32.800",
      "end": "00:00:34.600",
      "text": "在之前的几次错误开始之后"
    },
    {
      "id": "subtitle_018",
      "start": "00:00:34.600",
      "end": "00:00:37.033",
      "text": "美国人在1903年下到巴拿马"
    },
    {
      "id": "subtitle_019",
      "start": "00:00:37.033",
      "end": "00:00:39.700",
      "text": "签署了一个相当可疑的条约授予他们土地"
    },
    {
      "id": "subtitle_020",
      "start": "00:00:39.800",
      "end": "00:00:41.900",
      "text": "筑坝造人工湖"
    },
    {
      "id": "subtitle_021",
      "start": "00:00:41.933",
      "end": "00:00:43.866",
      "text": "挖了一条从那个湖到太平洋的战壕"
    },
    {
      "id": "subtitle_022",
      "start": "00:00:43.866",
      "end": "00:00:45.800",
      "text": "挖了一条从湖里到大西洋的战壕"
    },
    {
      "id": "subtitle_023",
      "start": "00:00:45.800",
      "end": "00:00:47.100",
      "text": "130亿美元"
    },
    {
      "id": "subtitle_024",
      "start": "00:00:47.100",
      "end": "00:00:49.500",
      "text": "5600名工人死亡"
    },
    {
      "id": "subtitle_025",
      "start": "00:00:49.500",
      "end": "00:00:50.866",
      "text": "运河修好了"
    },
    {
      "id": "subtitle_026",
      "start": "00:00:51.166",
      "end": "00:00:53.033",
      "text": "它正式打开了太平洋到大西洋的大门"
    },
    {
      "id": "subtitle_027",
      "start": "00:00:53.033",
      "end": "00:00:54.666",
      "text": "1914年8月15日"
    },
    {
      "id": "subtitle_028",
      "start": "00:00:55.000",
      "end": "00:00:58.500",
      "text": "作为SSN的第一艘商船驶过"
    },
    {
      "id": "subtitle_029",
      "start": "00:00:58.800",
      "end": "00:01:01.600",
      "text": "现在巴拿马运河不仅仅是一条直线"
    },
    {
      "id": "subtitle_030",
      "start": "00:01:01.600",
      "end": "00:01:02.966",
      "text": "从海洋到海洋"
    },
    {
      "id": "subtitle_031",
      "start": "00:01:03.166",
      "end": "00:01:05.100",
      "text": "那是因为他们创造的人工湖"
    },
    {
      "id": "subtitle_032",
      "start": "00:01:05.100",
      "end": "00:01:09.233",
      "text": "加屯湖海拔85英尺或26米"
    },
    {
      "id": "subtitle_033",
      "start": "00:01:09.366",
      "end": "00:01:10.633",
      "text": "所以货船"
    },
    {
      "id": "subtitle_034",
      "start": "00:01:10.633",
      "end": "00:01:12.866",
      "text": "重量超过10亿磅"
    },
    {
      "id": "subtitle_035",
      "start": "00:01:12.866",
      "end": "00:01:15.066",
      "text": "需要爬上那85英尺或者"
    },
    {
      "id": "subtitle_036",
      "start": "00:01:15.166",
      "end": "00:01:17.200",
      "text": "26米然后再往回倒"
    },
    {
      "id": "subtitle_037",
      "start": "00:01:17.200",
      "end": "00:01:19.266",
      "text": "从一个海洋到另一个海洋"
    },
    {
      "id": "subtitle_038",
      "start": "00:01:19.600",
      "end": "00:01:23.900",
      "text": "像大多数运河一样，巴拿马运河也使用水闸。"
    },
    {
      "id": "subtitle_039",
      "start": "00:01:24.300",
      "end": "00:01:26.000",
      "text": "例如，从大西洋一侧"
    },
    {
      "id": "subtitle_040",
      "start": "00:01:26.000",
      "end": "00:01:27.700",
      "text": "一艘船将被拉进第一个船闸"
    },
    {
      "id": "subtitle_041",
      "start": "00:01:27.700",
      "end": "00:01:28.566",
      "text": "在拖车旁边"
    },
    {
      "id": "subtitle_042",
      "start": "00:01:28.566",
      "end": "00:01:29.600",
      "text": "在运河的两边"
    },
    {
      "id": "subtitle_043",
      "start": "00:01:29.600",
      "end": "00:01:31.066",
      "text": "下游的闸门会关闭"
    },
    {
      "id": "subtitle_044",
      "start": "00:01:31.066",
      "end": "00:01:33.400",
      "text": "上游的水将被输入来填满水闸"
    },
    {
      "id": "subtitle_045",
      "start": "00:01:33.400",
      "end": "00:01:34.566",
      "text": "船会浮起来"
    },
    {
      "id": "subtitle_046",
      "start": "00:01:34.566",
      "end": "00:01:35.966",
      "text": "那么一旦水位上升"
    },
    {
      "id": "subtitle_047",
      "start": "00:01:35.966",
      "end": "00:01:37.566",
      "text": "与下一个锁的匹配"
    },
    {
      "id": "subtitle_048",
      "start": "00:01:37.566",
      "end": "00:01:38.500",
      "text": "大门就会打开"
    },
    {
      "id": "subtitle_049",
      "start": "00:01:38.500",
      "end": "00:01:40.633",
      "text": "船会被拉进下一个船闸"
    },
    {
      "id": "subtitle_050",
      "start": "00:01:41.233",
      "end": "00:01:42.600",
      "text": "然后大门就会关闭"
    },
    {
      "id": "subtitle_051",
      "start": "00:01:42.600",
      "end": "00:01:45.000",
      "text": "水位会再次上升，大门会打开"
    },
    {
      "id": "subtitle_052",
      "start": "00:01:45.000",
      "end": "00:01:46.600",
      "text": "那么这一切都会再次发生"
    },
    {
      "id": "subtitle_053",
      "start": "00:01:46.600",
      "end": "00:01:47.500",
      "text": "直到第三把锁"
    },
    {
      "id": "subtitle_054",
      "start": "00:01:47.500",
      "end": "00:01:49.900",
      "text": "把船抬到加丁湖的水位"
    },
    {
      "id": "subtitle_055",
      "start": "00:01:49.900",
      "end": "00:01:53.033",
      "text": "那些海拔85英尺或26米"
    },
    {
      "id": "subtitle_056",
      "start": "00:01:53.166",
      "end": "00:01:54.000",
      "text": "信不信由你"
    },
    {
      "id": "subtitle_057",
      "start": "00:01:54.000",
      "end": "00:01:55.166",
      "text": "就是这三个湖"
    },
    {
      "id": "subtitle_058",
      "start": "00:01:55.166",
      "end": "00:01:57.300",
      "text": "专门限制什么尺寸"
    },
    {
      "id": "subtitle_059",
      "start": "00:01:57.300",
      "end": "00:01:59.800",
      "text": "世界上很大一部分集装箱船队"
    },
    {
      "id": "subtitle_060",
      "start": "00:01:59.800",
      "end": "00:02:02.433",
      "text": "可以是一艘船必须在1200以下"
    },
    {
      "id": "subtitle_061",
      "start": "00:02:02.466",
      "end": "00:02:04.600",
      "text": "英尺或366米长"
    },
    {
      "id": "subtitle_062",
      "start": "00:02:04.600",
      "end": "00:02:06.266",
      "text": "和168英尺"
    },
    {
      "id": "subtitle_063",
      "start": "00:02:06.266",
      "end": "00:02:09.100",
      "text": "或者51米宽才能被巴拿马运河接受"
    },
    {
      "id": "subtitle_064",
      "start": "00:02:09.166",
      "end": "00:02:12.033",
      "text": "所以世界上很大一部分船只是建造的"
    },
    {
      "id": "subtitle_065",
      "start": "00:02:12.033",
      "end": "00:02:13.666",
      "text": "确切地说"
    },
    {
      "id": "subtitle_066",
      "start": "00:02:13.666",
      "end": "00:02:17.766",
      "text": "这个尺寸这个级别的船叫做Neo Panamax"
    },
    {
      "id": "subtitle_067",
      "start": "00:02:17.766",
      "end": "00:02:19.800",
      "text": "或新巴拿马型或后巴拿马型"
    },
    {
      "id": "subtitle_068",
      "start": "00:02:19.800",
      "end": "00:02:21.366",
      "text": "取决于你问谁"
    },
    {
      "id": "subtitle_069",
      "start": "00:02:21.466",
      "end": "00:02:22.200",
      "text": "当然"
    },
    {
      "id": "subtitle_070",
      "start": "00:02:22.200",
      "end": "00:02:24.633",
      "text": "肯定有比新巴拿马号更大的船"
    },
    {
      "id": "subtitle_071",
      "start": "00:02:24.633",
      "end": "00:02:27.900",
      "text": "尺寸巴拿马运河的尺寸限制约为"
    },
    {
      "id": "subtitle_072",
      "start": "00:02:28.400",
      "end": "00:02:31.266",
      "text": "15000标准箱或20英尺当量单位"
    },
    {
      "id": "subtitle_073",
      "start": "00:02:31.266",
      "end": "00:02:33.100",
      "text": "那是测量一艘船的载客量"
    },
    {
      "id": "subtitle_074",
      "start": "00:02:33.100",
      "end": "00:02:34.466",
      "text": "根据这些有多少"
    },
    {
      "id": "subtitle_075",
      "start": "00:02:34.466",
      "end": "00:02:36.166",
      "text": "他们可以携带20英尺长的集装箱"
    },
    {
      "id": "subtitle_076",
      "start": "00:02:36.633",
      "end": "00:02:38.966",
      "text": "现在最大的集装箱船"
    },
    {
      "id": "subtitle_077",
      "start": "00:02:38.966",
      "end": "00:02:42.033",
      "text": "东方海外香港有限公司的容量超过"
    },
    {
      "id": "subtitle_078",
      "start": "00:02:43.000",
      "end": "00:02:44.166",
      "text": "21 000标准箱"
    },
    {
      "id": "subtitle_079",
      "start": "00:02:44.433",
      "end": "00:02:47.666",
      "text": "这艘船和许多大于15000标准箱的船一样"
    },
    {
      "id": "subtitle_080",
      "start": "00:02:47.666",
      "end": "00:02:50.400",
      "text": "专营东亚至欧洲航线"
    },
    {
      "id": "subtitle_081",
      "start": "00:02:50.400",
      "end": "00:02:50.900",
      "text": "因为它不能"
    },
    {
      "id": "subtitle_082",
      "start": "00:02:50.900",
      "end": "00:02:52.900",
      "text": "高效地进行需要过境的旅行"
    },
    {
      "id": "subtitle_083",
      "start": "00:02:52.900",
      "end": "00:02:54.433",
      "text": "在太平洋和大西洋之间"
    },
    {
      "id": "subtitle_084",
      "start": "00:02:54.433",
      "end": "00:02:55.633",
      "text": "因为它必须规避"
    },
    {
      "id": "subtitle_085",
      "start": "00:02:55.866",
      "end": "00:02:56.866",
      "text": "南美洲"
    },
    {
      "id": "subtitle_086",
      "start": "00:02:57.133",
      "end": "00:02:58.500",
      "text": "那真是不久前的事了"
    },
    {
      "id": "subtitle_087",
      "start": "00:02:58.500",
      "end": "00:02:59.466",
      "text": "大型船只"
    },
    {
      "id": "subtitle_088",
      "start": "00:02:59.466",
      "end": "00:03:01.066",
      "text": "可以通过巴拿马运河"
    },
    {
      "id": "subtitle_089",
      "start": "00:03:01.066",
      "end": "00:03:03.066",
      "text": "远小于水流"
    },
    {
      "id": "subtitle_090",
      "start": "00:03:03.266",
      "end": "00:03:04.766",
      "text": "1500标准箱尺寸"
    },
    {
      "id": "subtitle_091",
      "start": "00:03:04.866",
      "end": "00:03:06.900",
      "text": "直到2016年"
    },
    {
      "id": "subtitle_092",
      "start": "00:03:06.900",
      "end": "00:03:10.500",
      "text": "巴拿马运河只能容纳小于"
    },
    {
      "id": "subtitle_093",
      "start": "00:03:10.500",
      "end": "00:03:11.300",
      "text": "5000标准箱"
    },
    {
      "id": "subtitle_094",
      "start": "00:03:11.600",
      "end": "00:03:15.166",
      "text": "那是因为直到2016年，这些都不存在。"
    },
    {
      "id": "subtitle_095",
      "start": "00:03:15.166",
      "end": "00:03:17.700",
      "text": "巴拿马运河的新船闸"
    },
    {
      "id": "subtitle_096",
      "start": "00:03:17.866",
      "end": "00:03:19.800",
      "text": "旧船闸只能装一艘船"
    },
    {
      "id": "subtitle_097",
      "start": "00:03:19.866",
      "end": "00:03:21.900",
      "text": "106英尺或32米宽"
    },
    {
      "id": "subtitle_098",
      "start": "00:03:21.900",
      "end": "00:03:22.600",
      "text": "但还是"
    },
    {
      "id": "subtitle_099",
      "start": "00:03:22.600",
      "end": "00:03:25.166",
      "text": "鉴于这条水道的重要性"
    },
    {
      "id": "subtitle_100",
      "start": "00:03:25.166",
      "end": "00:03:26.500",
      "text": "当时还在建造船只"
    },
    {
      "id": "subtitle_101",
      "start": "00:03:26.500",
      "end": "00:03:28.566",
      "text": "专门为了适应"
    },
    {
      "id": "subtitle_102",
      "start": "00:03:28.833",
      "end": "00:03:31.666",
      "text": "事实上50个旧块用户"
    },
    {
      "id": "subtitle_103",
      "start": "00:03:31.666",
      "end": "00:03:34.000",
      "text": "正好和这个宽度限制一样宽"
    },
    {
      "id": "subtitle_104",
      "start": "00:03:34.000",
      "end": "00:03:36.266",
      "text": "表明它们很可能是为"
    },
    {
      "id": "subtitle_105",
      "start": "00:03:36.266",
      "end": "00:03:37.500",
      "text": "那个目的"
    },
    {
      "id": "subtitle_106",
      "start": "00:03:37.766",
      "end": "00:03:39.833",
      "text": "这对巴拿马运河来说是个问题"
    },
    {
      "id": "subtitle_107",
      "start": "00:03:39.833",
      "end": "00:03:41.166",
      "text": "因为信不信由你"
    },
    {
      "id": "subtitle_108",
      "start": "00:03:41.200",
      "end": "00:03:43.633",
      "text": "运河有竞争对手"
    },
    {
      "id": "subtitle_109",
      "start": "00:03:43.766",
      "end": "00:03:45.700",
      "text": "这都和地理有关"
    },
    {
      "id": "subtitle_110",
      "start": "00:03:45.700",
      "end": "00:03:48.400",
      "text": "从东亚到美国东海岸旅行时"
    },
    {
      "id": "subtitle_111",
      "start": "00:03:48.400",
      "end": "00:03:49.766",
      "text": "这是最繁忙的航线之一"
    },
    {
      "id": "subtitle_112",
      "start": "00:03:49.766",
      "end": "00:03:50.566",
      "text": "在世界上"
    },
    {
      "id": "subtitle_113",
      "start": "00:03:50.633",
      "end": "00:03:53.700",
      "text": "向西走真的不远"
    },
    {
      "id": "subtitle_114",
      "start": "00:03:53.700",
      "end": "00:03:57.033",
      "text": "而不是从香港到纽约的东部"
    },
    {
      "id": "subtitle_115",
      "start": "00:03:57.033",
      "end": "00:03:59.300",
      "text": "向西穿过印度洋的距离"
    },
    {
      "id": "subtitle_116",
      "start": "00:03:59.300",
      "end": "00:04:01.500",
      "text": "苏伊士运河地中海和大西洋"
    },
    {
      "id": "subtitle_117",
      "start": "00:04:01.500",
      "end": "00:04:04.033",
      "text": "只有几百英里或公里长"
    },
    {
      "id": "subtitle_118",
      "start": "00:04:04.033",
      "end": "00:04:05.666",
      "text": "而不是向东横跨太平洋"
    },
    {
      "id": "subtitle_119",
      "start": "00:04:05.666",
      "end": "00:04:07.033",
      "text": "通过巴拿马运河"
    },
    {
      "id": "subtitle_120",
      "start": "00:04:07.433",
      "end": "00:04:10.500",
      "text": "同时巴拿马运河也不便宜"
    },
    {
      "id": "subtitle_121",
      "start": "00:04:10.600",
      "end": "00:04:13.666",
      "text": "他们每20英尺集装箱收费90美元"
    },
    {
      "id": "subtitle_122",
      "start": "00:04:13.666",
      "end": "00:04:14.866",
      "text": "这意味着大多数船只"
    },
    {
      "id": "subtitle_123",
      "start": "00:04:14.866",
      "end": "00:04:17.066",
      "text": "载着数千个装载的集装箱"
    },
    {
      "id": "subtitle_124",
      "start": "00:04:17.066",
      "end": "00:04:18.966",
      "text": "支付数十万美元"
    },
    {
      "id": "subtitle_125",
      "start": "00:04:18.966",
      "end": "00:04:20.833",
      "text": "只需一次运输"
    },
    {
      "id": "subtitle_126",
      "start": "00:04:21.066",
      "end": "00:04:23.100",
      "text": "有了新锁和更高的容量"
    },
    {
      "id": "subtitle_127",
      "start": "00:04:23.100",
      "end": "00:04:23.866",
      "text": "单船"
    },
    {
      "id": "subtitle_128",
      "start": "00:04:23.866",
      "end": "00:04:26.566",
      "text": "可能超过100万美元"
    },
    {
      "id": "subtitle_129",
      "start": "00:04:26.566",
      "end": "00:04:29.566",
      "text": "如果它们是最大尺寸的满载，则每次运输"
    },
    {
      "id": "subtitle_130",
      "start": "00:04:29.833",
      "end": "00:04:33.000",
      "text": "与此同时，苏伊士运河通常收取较低的通行费"
    },
    {
      "id": "subtitle_131",
      "start": "00:04:33.066",
      "end": "00:04:35.266",
      "text": "从香港开往纽约的船"
    },
    {
      "id": "subtitle_132",
      "start": "00:04:35.266",
      "end": "00:04:35.766",
      "text": "因此"
    },
    {
      "id": "subtitle_133",
      "start": "00:04:35.766",
      "end": "00:04:37.900",
      "text": "可能会选择稍微长一点的路线"
    },
    {
      "id": "subtitle_134",
      "start": "00:04:37.900",
      "end": "00:04:39.066",
      "text": "经由苏伊士运河"
    },
    {
      "id": "subtitle_135",
      "start": "00:04:39.066",
      "end": "00:04:40.400",
      "text": "对巴拿马运河"
    },
    {
      "id": "subtitle_136",
      "start": "00:04:40.400",
      "end": "00:04:42.900",
      "text": "最终当你考虑通行费时"
    },
    {
      "id": "subtitle_137",
      "start": "00:04:42.900",
      "end": "00:04:45.200",
      "text": "它最终可能会更便宜。"
    },
    {
      "id": "subtitle_138",
      "start": "00:04:45.466",
      "end": "00:04:48.000",
      "text": "现在两条运河都在不断改变收费标准"
    },
    {
      "id": "subtitle_139",
      "start": "00:04:48.000",
      "end": "00:04:49.566",
      "text": "为了与对方竞争"
    },
    {
      "id": "subtitle_140",
      "start": "00:04:49.566",
      "end": "00:04:51.633",
      "text": "但在过去的十年里"
    },
    {
      "id": "subtitle_141",
      "start": "00:04:51.633",
      "end": "00:04:55.633",
      "text": "苏伊士运河的成本似乎略有上升"
    },
    {
      "id": "subtitle_142",
      "start": "00:04:55.700",
      "end": "00:04:59.066",
      "text": "巴拿马运河的另一个竞争者是火车"
    },
    {
      "id": "subtitle_143",
      "start": "00:04:59.066",
      "end": "00:05:02.066",
      "text": "重要的东亚至美国东海岸航线"
    },
    {
      "id": "subtitle_144",
      "start": "00:05:02.066",
      "end": "00:05:03.666",
      "text": "通过巴拿马运河"
    },
    {
      "id": "subtitle_145",
      "start": "00:05:03.666",
      "end": "00:05:06.166",
      "text": "虽然比环游大陆快得多"
    },
    {
      "id": "subtitle_146",
      "start": "00:05:06.166",
      "end": "00:05:08.266",
      "text": "仍然不是直接路线"
    },
    {
      "id": "subtitle_147",
      "start": "00:05:08.500",
      "end": "00:05:10.033",
      "text": "在香港到纽约的航线上"
    },
    {
      "id": "subtitle_148",
      "start": "00:05:10.033",
      "end": "00:05:12.466",
      "text": "巴拿马运河代表着"
    },
    {
      "id": "subtitle_149",
      "start": "00:05:12.800",
      "end": "00:05:16.433",
      "text": "一英里或五千公里的分流"
    },
    {
      "id": "subtitle_150",
      "start": "00:05:16.633",
      "end": "00:05:18.700",
      "text": "陆路穿越美国"
    },
    {
      "id": "subtitle_151",
      "start": "00:05:19.033",
      "end": "00:05:21.500",
      "text": "这是相当标准的做法装运货物从"
    },
    {
      "id": "subtitle_152",
      "start": "00:05:21.500",
      "end": "00:05:23.100",
      "text": "东亚到洛杉矶"
    },
    {
      "id": "subtitle_153",
      "start": "00:05:23.100",
      "end": "00:05:24.800",
      "text": "然后装上火车去拿"
    },
    {
      "id": "subtitle_154",
      "start": "00:05:24.800",
      "end": "00:05:26.266",
      "text": "到美国东海岸"
    },
    {
      "id": "subtitle_155",
      "start": "00:05:26.500",
      "end": "00:05:27.200",
      "text": "虽然总体"
    },
    {
      "id": "subtitle_156",
      "start": "00:05:27.200",
      "end": "00:05:29.100",
      "text": "这通常会更贵一点。"
    },
    {
      "id": "subtitle_157",
      "start": "00:05:29.100",
      "end": "00:05:30.633",
      "text": "而不是通过巴拿马运河"
    },
    {
      "id": "subtitle_158",
      "start": "00:05:30.666",
      "end": "00:05:32.800",
      "text": "它节省了大约一周的运输时间"
    },
    {
      "id": "subtitle_159",
      "start": "00:05:32.800",
      "end": "00:05:35.800",
      "text": "对于许多托运人来说，这是值得的"
    },
    {
      "id": "subtitle_160",
      "start": "00:05:36.000",
      "end": "00:05:38.066",
      "text": "成本相对较低的火车"
    },
    {
      "id": "subtitle_161",
      "start": "00:05:38.066",
      "end": "00:05:40.766",
      "text": "代表着运河的一个相当大的竞争对手"
    },
    {
      "id": "subtitle_162",
      "start": "00:05:40.766",
      "end": "00:05:42.566",
      "text": "这是与这些的竞争"
    },
    {
      "id": "subtitle_163",
      "start": "00:05:42.566",
      "end": "00:05:43.766",
      "text": "还有苏伊士运河"
    },
    {
      "id": "subtitle_164",
      "start": "00:05:43.766",
      "end": "00:05:46.633",
      "text": "推动巴拿马运河扩张"
    },
    {
      "id": "subtitle_165",
      "start": "00:05:46.766",
      "end": "00:05:48.100",
      "text": "这就是为什么他们花了5英镑。"
    },
    {
      "id": "subtitle_166",
      "start": "00:05:48.400",
      "end": "00:05:50.500",
      "text": "40亿美元来造这些更大的锁"
    },
    {
      "id": "subtitle_167",
      "start": "00:05:50.500",
      "end": "00:05:51.833",
      "text": "那可能适合更大的"
    },
    {
      "id": "subtitle_168",
      "start": "00:05:51.900",
      "end": "00:05:53.833",
      "text": "15000标准箱船"
    },
    {
      "id": "subtitle_169",
      "start": "00:05:54.000",
      "end": "00:05:55.866",
      "text": "这将让世界上更多的船队"
    },
    {
      "id": "subtitle_170",
      "start": "00:05:55.866",
      "end": "00:05:56.433",
      "text": "通过"
    },
    {
      "id": "subtitle_171",
      "start": "00:05:56.433",
      "end": "00:05:58.866",
      "text": "由于规模经济，这些更大的船"
    },
    {
      "id": "subtitle_172",
      "start": "00:05:58.866",
      "end": "00:06:00.400",
      "text": "每个容器的成本较低"
    },
    {
      "id": "subtitle_173",
      "start": "00:06:00.400",
      "end": "00:06:02.366",
      "text": "这有助于使运河更具吸引力"
    },
    {
      "id": "subtitle_174",
      "start": "00:06:02.366",
      "end": "00:06:03.800",
      "text": "与火车相比"
    },
    {
      "id": "subtitle_175",
      "start": "00:06:03.800",
      "end": "00:06:05.300",
      "text": "或者苏伊士的竞争对手"
    },
    {
      "id": "subtitle_176",
      "start": "00:06:05.700",
      "end": "00:06:08.200",
      "text": "现在这个扩展是一个很好的例子"
    },
    {
      "id": "subtitle_177",
      "start": "00:06:08.200",
      "end": "00:06:09.633",
      "text": "蝴蝶效应"
    },
    {
      "id": "subtitle_178",
      "start": "00:06:09.666",
      "end": "00:06:10.700",
      "text": "在一个例子中"
    },
    {
      "id": "subtitle_179",
      "start": "00:06:10.700",
      "end": "00:06:12.166",
      "text": "因为巴拿马运河"
    },
    {
      "id": "subtitle_180",
      "start": "00:06:12.166",
      "end": "00:06:14.500",
      "text": "把它的尺寸限制扩大了几十英尺"
    },
    {
      "id": "subtitle_181",
      "start": "00:06:14.500",
      "end": "00:06:16.633",
      "text": "新泽西州不得不花1美元"
    },
    {
      "id": "subtitle_182",
      "start": "00:06:16.866",
      "end": "00:06:20.300",
      "text": "70亿美元把桥抬高几十英尺"
    },
    {
      "id": "subtitle_183",
      "start": "00:06:20.566",
      "end": "00:06:23.433",
      "text": "你看，为了到达纽瓦克的大部分港口"
    },
    {
      "id": "subtitle_184",
      "start": "00:06:23.433",
      "end": "00:06:25.366",
      "text": "这是美国最大、最繁忙的城市之一"
    },
    {
      "id": "subtitle_185",
      "start": "00:06:25.366",
      "end": "00:06:28.366",
      "text": "S船必须从巴约恩桥下通过"
    },
    {
      "id": "subtitle_186",
      "start": "00:06:28.466",
      "end": "00:06:30.900",
      "text": "占到美国海运的很大一部分"
    },
    {
      "id": "subtitle_187",
      "start": "00:06:30.900",
      "end": "00:06:32.900",
      "text": "东海岸穿过巴拿马运河"
    },
    {
      "id": "subtitle_188",
      "start": "00:06:32.900",
      "end": "00:06:34.166",
      "text": "在新锁之前"
    },
    {
      "id": "subtitle_189",
      "start": "00:06:34.166",
      "end": "00:06:35.033",
      "text": "许多船只"
    },
    {
      "id": "subtitle_190",
      "start": "00:06:35.033",
      "end": "00:06:36.966",
      "text": "想利用纽瓦克港"
    },
    {
      "id": "subtitle_191",
      "start": "00:06:36.966",
      "end": "00:06:38.233",
      "text": "是小一号的吗？"
    },
    {
      "id": "subtitle_192",
      "start": "00:06:38.233",
      "end": "00:06:40.066",
      "text": "这些都可以放在巴约恩桥下"
    },
    {
      "id": "subtitle_193",
      "start": "00:06:40.066",
      "end": "00:06:42.233",
      "text": "坐在151英尺或"
    },
    {
      "id": "subtitle_194",
      "start": "00:06:42.433",
      "end": "00:06:43.966",
      "text": "水面以上46米"
    },
    {
      "id": "subtitle_195",
      "start": "00:06:44.266",
      "end": "00:06:46.433",
      "text": "运河扩建工程"
    },
    {
      "id": "subtitle_196",
      "start": "00:06:46.433",
      "end": "00:06:48.433",
      "text": "会有更多的船开往纽约"
    },
    {
      "id": "subtitle_197",
      "start": "00:06:48.433",
      "end": "00:06:49.433",
      "text": "那就太大了"
    },
    {
      "id": "subtitle_198",
      "start": "00:06:49.433",
      "end": "00:06:51.233",
      "text": "以适应Bayonne大桥下"
    },
    {
      "id": "subtitle_199",
      "start": "00:06:51.400",
      "end": "00:06:52.100",
      "text": "因此"
    },
    {
      "id": "subtitle_200",
      "start": "00:06:52.100",
      "end": "00:06:54.500",
      "text": "为了让纽约港保持竞争力"
    },
    {
      "id": "subtitle_201",
      "start": "00:06:54.500",
      "end": "00:06:57.400",
      "text": "他们只需要把桥架起来"
    },
    {
      "id": "subtitle_202",
      "start": "00:06:57.600",
      "end": "00:06:59.400",
      "text": "除此之外，美国上下都在"
    },
    {
      "id": "subtitle_203",
      "start": "00:06:59.400",
      "end": "00:07:00.266",
      "text": "东海岸"
    },
    {
      "id": "subtitle_204",
      "start": "00:07:00.266",
      "end": "00:07:02.233",
      "text": "从迈阿密到萨凡纳再到查尔斯顿"
    },
    {
      "id": "subtitle_205",
      "start": "00:07:02.233",
      "end": "00:07:03.700",
      "text": "去巴尔的摩和纽约"
    },
    {
      "id": "subtitle_206",
      "start": "00:07:03.700",
      "end": "00:07:04.666",
      "text": "港口迅速耗尽"
    },
    {
      "id": "subtitle_207",
      "start": "00:07:04.666",
      "end": "00:07:06.566",
      "text": "几百万和几十亿美元"
    },
    {
      "id": "subtitle_208",
      "start": "00:07:06.566",
      "end": "00:07:08.966",
      "text": "建造适合大型船只的设施"
    },
    {
      "id": "subtitle_209",
      "start": "00:07:08.966",
      "end": "00:07:11.600",
      "text": "正好赶上新运河水闸的开通"
    },
    {
      "id": "subtitle_210",
      "start": "00:07:11.866",
      "end": "00:07:12.800",
      "text": "不过今天还是"
    },
    {
      "id": "subtitle_211",
      "start": "00:07:12.800",
      "end": "00:07:14.366",
      "text": "东海岸的许多港口"
    },
    {
      "id": "subtitle_212",
      "start": "00:07:14.366",
      "end": "00:07:15.500",
      "text": "没有深度"
    },
    {
      "id": "subtitle_213",
      "start": "00:07:15.500",
      "end": "00:07:17.633",
      "text": "以及处理这些Neo所需的设施"
    },
    {
      "id": "subtitle_214",
      "start": "00:07:17.633",
      "end": "00:07:18.900",
      "text": "巴拿马船"
    },
    {
      "id": "subtitle_215",
      "start": "00:07:19.033",
      "end": "00:07:22.100",
      "text": "不过这也为加勒比海地区提供了一个机会"
    },
    {
      "id": "subtitle_216",
      "start": "00:07:22.566",
      "end": "00:07:24.066",
      "text": "加勒比海的深水港口"
    },
    {
      "id": "subtitle_217",
      "start": "00:07:24.066",
      "end": "00:07:27.866",
      "text": "正在发展成为主要的转运中心"
    },
    {
      "id": "subtitle_218",
      "start": "00:07:28.000",
      "end": "00:07:28.833",
      "text": "这些是什么"
    },
    {
      "id": "subtitle_219",
      "start": "00:07:28.833",
      "end": "00:07:30.466",
      "text": "是大型船只的港口"
    },
    {
      "id": "subtitle_220",
      "start": "00:07:30.466",
      "end": "00:07:32.266",
      "text": "比如最大的15000标准箱"
    },
    {
      "id": "subtitle_221",
      "start": "00:07:32.266",
      "end": "00:07:34.566",
      "text": "现在可以通过运河的集装箱船"
    },
    {
      "id": "subtitle_222",
      "start": "00:07:34.600",
      "end": "00:07:35.866",
      "text": "会卸下他们的货物"
    },
    {
      "id": "subtitle_223",
      "start": "00:07:35.866",
      "end": "00:07:38.433",
      "text": "然后将再次装载到较小的船上"
    },
    {
      "id": "subtitle_224",
      "start": "00:07:38.433",
      "end": "00:07:39.666",
      "text": "开往较小的港口"
    },
    {
      "id": "subtitle_225",
      "start": "00:07:39.666",
      "end": "00:07:41.366",
      "text": "更接近货物的目的地"
    },
    {
      "id": "subtitle_226",
      "start": "00:07:41.366",
      "end": "00:07:42.966",
      "text": "现在在东海岸"
    },
    {
      "id": "subtitle_227",
      "start": "00:07:43.400",
      "end": "00:07:44.966",
      "text": "巨额外币"
    },
    {
      "id": "subtitle_228",
      "start": "00:07:44.966",
      "end": "00:07:46.266",
      "text": "正流入加勒比海"
    },
    {
      "id": "subtitle_229",
      "start": "00:07:46.266",
      "end": "00:07:48.400",
      "text": "发展这些转运枢纽"
    },
    {
      "id": "subtitle_230",
      "start": "00:07:48.766",
      "end": "00:07:49.800",
      "text": "达飞集团"
    },
    {
      "id": "subtitle_231",
      "start": "00:07:49.800",
      "end": "00:07:51.000",
      "text": "一家来自法国的航运公司"
    },
    {
      "id": "subtitle_232",
      "start": "00:07:51.000",
      "end": "00:07:52.900",
      "text": "是世界第三大"
    },
    {
      "id": "subtitle_233",
      "start": "00:07:52.900",
      "end": "00:07:55.066",
      "text": "经营牙买加金斯敦港"
    },
    {
      "id": "subtitle_234",
      "start": "00:07:55.266",
      "end": "00:07:58.233",
      "text": "来自阿联酋的DP World运营Cayo Santo港"
    },
    {
      "id": "subtitle_235",
      "start": "00:07:58.233",
      "end": "00:07:59.566",
      "text": "在多米尼加共和国"
    },
    {
      "id": "subtitle_236",
      "start": "00:07:59.666",
      "end": "00:08:01.166",
      "text": "与此同时自由港港"
    },
    {
      "id": "subtitle_237",
      "start": "00:08:01.166",
      "end": "00:08:01.900",
      "text": "在巴哈马群岛"
    },
    {
      "id": "subtitle_238",
      "start": "00:08:01.900",
      "end": "00:08:04.666",
      "text": "由和记港口控股在香港运营"
    },
    {
      "id": "subtitle_239",
      "start": "00:08:04.966",
      "end": "00:08:06.266",
      "text": "所有这些公司等等"
    },
    {
      "id": "subtitle_240",
      "start": "00:08:06.266",
      "end": "00:08:06.666",
      "text": "有"
    },
    {
      "id": "subtitle_241",
      "start": "00:08:06.666",
      "end": "00:08:09.366",
      "text": "并继续集中精力扩建这些古巴港口"
    },
    {
      "id": "subtitle_242",
      "start": "00:08:09.366",
      "end": "00:08:10.600",
      "text": "以适应增加的交通"
    },
    {
      "id": "subtitle_243",
      "start": "00:08:10.600",
      "end": "00:08:12.300",
      "text": "穿过巴拿马运河"
    },
    {
      "id": "subtitle_244",
      "start": "00:08:12.300",
      "end": "00:08:13.300",
      "text": "进入古巴"
    },
    {
      "id": "subtitle_245",
      "start": "00:08:13.300",
      "end": "00:08:16.200",
      "text": "最终到达东海岸的目的地"
    },
    {
      "id": "subtitle_246",
      "start": "00:08:16.300",
      "end": "00:08:17.433",
      "text": "不过很快就会"
    },
    {
      "id": "subtitle_247",
      "start": "00:08:17.433",
      "end": "00:08:18.400",
      "text": "可能会发生一些事情"
    },
    {
      "id": "subtitle_248",
      "start": "00:08:18.400",
      "end": "00:08:21.166",
      "text": "同时对古巴港口也有好处"
    },
    {
      "id": "subtitle_249",
      "start": "00:08:21.166",
      "end": "00:08:23.100",
      "text": "但对巴拿马运河来说很糟糕"
    },
    {
      "id": "subtitle_250",
      "start": "00:08:23.500",
      "end": "00:08:24.766",
      "text": "你看到两个国家"
    },
    {
      "id": "subtitle_251",
      "start": "00:08:24.766",
      "end": "00:08:26.800",
      "text": "巴拿马北部是尼加拉瓜"
    },
    {
      "id": "subtitle_252",
      "start": "00:08:26.900",
      "end": "00:08:28.900",
      "text": "通过连接大西洋和太平洋"
    },
    {
      "id": "subtitle_253",
      "start": "00:08:28.900",
      "end": "00:08:30.633",
      "text": "到尼加拉瓜湖"
    },
    {
      "id": "subtitle_254",
      "start": "00:08:30.666",
      "end": "00:08:33.966",
      "text": "海洋之间可能有另一种联系"
    },
    {
      "id": "subtitle_255",
      "start": "00:08:33.966",
      "end": "00:08:35.833",
      "text": "有很长的尝试历史"
    },
    {
      "id": "subtitle_256",
      "start": "00:08:35.833",
      "end": "00:08:36.866",
      "text": "修建这条运河"
    },
    {
      "id": "subtitle_257",
      "start": "00:08:36.866",
      "end": "00:08:38.300",
      "text": "最近一次是在过去十年中"
    },
    {
      "id": "subtitle_258",
      "start": "00:08:38.300",
      "end": "00:08:40.633",
      "text": "与一个中国亿万富翁的失败计划有关"
    },
    {
      "id": "subtitle_259",
      "start": "00:08:40.766",
      "end": "00:08:42.633",
      "text": "鉴于这次失败是最近的"
    },
    {
      "id": "subtitle_260",
      "start": "00:08:42.633",
      "end": "00:08:44.600",
      "text": "目前没有建设计划"
    },
    {
      "id": "subtitle_261",
      "start": "00:08:44.600",
      "end": "00:08:45.766",
      "text": "但至少在某个地方"
    },
    {
      "id": "subtitle_262",
      "start": "00:08:45.766",
      "end": "00:08:48.566",
      "text": "世界需要更多的运河容量"
    },
    {
      "id": "subtitle_263",
      "start": "00:08:48.566",
      "end": "00:08:50.666",
      "text": "在太平洋和大西洋之间"
    },
    {
      "id": "subtitle_264",
      "start": "00:08:50.766",
      "end": "00:08:52.166",
      "text": "航运业正在增长"
    },
    {
      "id": "subtitle_265",
      "start": "00:08:52.166",
      "end": "00:08:54.900",
      "text": "以每年约5%的稳定速度"
    },
    {
      "id": "subtitle_266",
      "start": "00:08:54.900",
      "end": "00:08:58.366",
      "text": "巴拿马运河只能扩张这么多"
    },
    {
      "id": "subtitle_267",
      "start": "00:08:58.700",
      "end": "00:09:00.600",
      "text": "一个问题是巴拿马运河"
    },
    {
      "id": "subtitle_268",
      "start": "00:09:00.600",
      "end": "00:09:02.433",
      "text": "可能真的用完了水"
    },
    {
      "id": "subtitle_269",
      "start": "00:09:02.600",
      "end": "00:09:05.233",
      "text": "每次运河的水闸打开"
    },
    {
      "id": "subtitle_270",
      "start": "00:09:05.233",
      "end": "00:09:08.833",
      "text": "数百万加仑的水流向下游"
    },
    {
      "id": "subtitle_271",
      "start": "00:09:09.166",
      "end": "00:09:10.466",
      "text": "通常这不是问题"
    },
    {
      "id": "subtitle_272",
      "start": "00:09:10.466",
      "end": "00:09:12.633",
      "text": "因为上游的湖泊有足够的水"
    },
    {
      "id": "subtitle_273",
      "start": "00:09:12.633",
      "end": "00:09:15.633",
      "text": "但有时在降雨量减少的时期"
    },
    {
      "id": "subtitle_274",
      "start": "00:09:15.633",
      "end": "00:09:17.900",
      "text": "只是没有足够的水来释放"
    },
    {
      "id": "subtitle_275",
      "start": "00:09:17.900",
      "end": "00:09:19.700",
      "text": "操作锁所需的金额"
    },
    {
      "id": "subtitle_276",
      "start": "00:09:19.700",
      "end": "00:09:21.566",
      "text": "保持湖水足够深"
    },
    {
      "id": "subtitle_277",
      "start": "00:09:21.566",
      "end": "00:09:23.266",
      "text": "供最大的船只过境"
    },
    {
      "id": "subtitle_278",
      "start": "00:09:23.533",
      "end": "00:09:26.500",
      "text": "在这些时间，包括2019年春季的大部分时间"
    },
    {
      "id": "subtitle_279",
      "start": "00:09:26.566",
      "end": "00:09:28.300",
      "text": "运河将不得不设置限制"
    },
    {
      "id": "subtitle_280",
      "start": "00:09:28.300",
      "end": "00:09:29.366",
      "text": "重量是多少？"
    },
    {
      "id": "subtitle_281",
      "start": "00:09:29.366",
      "end": "00:09:30.633",
      "text": "货船可以携带"
    },
    {
      "id": "subtitle_282",
      "start": "00:09:30.633",
      "end": "00:09:33.300",
      "text": "因为这会影响它们在水中的深度"
    },
    {
      "id": "subtitle_283",
      "start": "00:09:33.666",
      "end": "00:09:35.300",
      "text": "他们试图限制这种影响"
    },
    {
      "id": "subtitle_284",
      "start": "00:09:35.300",
      "end": "00:09:37.700",
      "text": "通过安装系统来回收一些水"
    },
    {
      "id": "subtitle_285",
      "start": "00:09:37.700",
      "end": "00:09:39.033",
      "text": "用来操作锁"
    },
    {
      "id": "subtitle_286",
      "start": "00:09:39.033",
      "end": "00:09:39.566",
      "text": "还有"
    },
    {
      "id": "subtitle_287",
      "start": "00:09:39.566",
      "end": "00:09:41.233",
      "text": "建造附加设施的潜在计划"
    },
    {
      "id": "subtitle_288",
      "start": "00:09:41.233",
      "end": "00:09:43.500",
      "text": "上游大坝增建水库"
    },
    {
      "id": "subtitle_289",
      "start": "00:09:43.500",
      "end": "00:09:45.866",
      "text": "但这些问题预计只会恶化"
    },
    {
      "id": "subtitle_290",
      "start": "00:09:45.866",
      "end": "00:09:46.766",
      "text": "随着气候变化"
    },
    {
      "id": "subtitle_291",
      "start": "00:09:46.766",
      "end": "00:09:49.433",
      "text": "加剧了该地区干旱的严重性"
    },
    {
      "id": "subtitle_292",
      "start": "00:09:49.866",
      "end": "00:09:53.500",
      "text": "巴拿马发生的事影响了全世界"
    },
    {
      "id": "subtitle_293",
      "start": "00:09:53.500",
      "end": "00:09:54.233",
      "text": "如果干旱"
    },
    {
      "id": "subtitle_294",
      "start": "00:09:54.233",
      "end": "00:09:56.833",
      "text": "在巴拿马限制了运河的吞吐量"
    },
    {
      "id": "subtitle_295",
      "start": "00:09:56.900",
      "end": "00:09:59.100",
      "text": "世界经济将会感受到"
    },
    {
      "id": "subtitle_296",
      "start": "00:09:59.466",
      "end": "00:09:59.900",
      "text": "那是因为"
    },
    {
      "id": "subtitle_297",
      "start": "00:09:59.900",
      "end": "00:10:02.400",
      "text": "航运是连接世界经济的纽带"
    },
    {
      "id": "subtitle_298",
      "start": "00:10:02.400",
      "end": "00:10:03.366",
      "text": "还有巴拿马运河"
    },
    {
      "id": "subtitle_299",
      "start": "00:10:03.366",
      "end": "00:10:05.666",
      "text": "是最重要的连接器之一"
    },
    {
      "id": "subtitle_300",
      "start": "00:10:05.666",
      "end": "00:10:06.600",
      "text": "在运输中"
    },
    {
      "id": "subtitle_301",
      "start": "00:10:06.900",
      "end": "00:10:09.766",
      "text": "运河有效地把经济带到了一边"
    },
    {
      "id": "subtitle_302",
      "start": "00:10:09.766",
      "end": "00:10:11.433",
      "text": "更接近另一个"
    },
    {
      "id": "subtitle_303",
      "start": "00:10:11.433",
      "end": "00:10:13.466",
      "text": "所以无论发生什么"
    },
    {
      "id": "subtitle_304",
      "start": "00:10:13.466",
      "end": "00:10:16.633",
      "text": "它将继续成为世界的捷径"
    },
    {
      "id": "subtitle_305",
      "start": "00:10:17.766",
      "end": "00:10:18.900",
      "text": "现在有一件事"
    },
    {
      "id": "subtitle_306",
      "start": "00:10:18.900",
      "end": "00:10:20.400",
      "text": "那些在巴拿马运河工作的人"
    },
    {
      "id": "subtitle_307",
      "start": "00:10:20.400",
      "end": "00:10:21.400",
      "text": "需要了解"
    },
    {
      "id": "subtitle_308",
      "start": "00:10:21.400",
      "end": "00:10:23.266",
      "text": "水是如何工作的"
    },
    {
      "id": "subtitle_309",
      "start": "00:10:23.266",
      "end": "00:10:24.800",
      "text": "就像天气如何运作一样"
    },
    {
      "id": "subtitle_310",
      "start": "00:10:24.800",
      "end": "00:10:27.166",
      "text": "水循环如何运作，潮汐如何运作"
    },
    {
      "id": "subtitle_311",
      "start": "00:10:27.166",
      "end": "00:10:29.533",
      "text": "所有这些东西也是概念"
    }
  ]
}
