{
  "version": 1,
  "source_subtitle": "火星车靠啥自己探路？到了火星谁在替人干活_时间线02.srt",
  "output_audio": "火星车靠啥自己探路？到了火星谁在替人干活_时间线02_中文字幕直读_Yunyang.mp3",
  "mode": "verbatim_chinese_subtitle_audio",
  "voice": "zh-CN-YunyangNeural",
  "rate": "+0%",
  "video_duration": "00:16:31.376",
  "segments": [
    {
      "id": "subtitle_001",
      "start": "00:00:01.500",
      "end": "00:00:04.333",
      "text": "这就是火星漫游者的毅力"
    },
    {
      "id": "subtitle_002",
      "start": "00:00:04.333",
      "end": "00:00:07.533",
      "text": "登陆另一个星球的最先进的机器人"
    },
    {
      "id": "subtitle_003",
      "start": "00:00:07.900",
      "end": "00:00:10.533",
      "text": "在这个视频中，我们将看看它是如何建造的"
    },
    {
      "id": "subtitle_004",
      "start": "00:00:11.033",
      "end": "00:00:12.900",
      "text": "Atlas 5发布"
    },
    {
      "id": "subtitle_005",
      "start": "00:00:13.233",
      "end": "00:00:14.800",
      "text": "火星之旅"
    },
    {
      "id": "subtitle_006",
      "start": "00:00:15.066",
      "end": "00:00:16.800",
      "text": "和科学仪器"
    },
    {
      "id": "subtitle_007",
      "start": "00:00:16.800",
      "end": "00:00:18.900",
      "text": "让它能够研究表面"
    },
    {
      "id": "subtitle_008",
      "start": "00:00:32.400",
      "end": "00:00:34.200",
      "text": "2021年2月"
    },
    {
      "id": "subtitle_009",
      "start": "00:00:34.200",
      "end": "00:00:38.466",
      "text": "一辆坚持不懈的漫游者成功登陆火星"
    },
    {
      "id": "subtitle_010",
      "start": "00:00:39.000",
      "end": "00:00:42.466",
      "text": "总共要花250亿美元"
    },
    {
      "id": "subtitle_011",
      "start": "00:00:42.933",
      "end": "00:00:45.900",
      "text": "它有许多科学仪器来帮助研究火星"
    },
    {
      "id": "subtitle_012",
      "start": "00:00:45.900",
      "end": "00:00:47.466",
      "text": "寻找生命迹象"
    },
    {
      "id": "subtitle_013",
      "start": "00:00:47.466",
      "end": "00:00:50.400",
      "text": "并为未来的人类探险家铺平道路"
    },
    {
      "id": "subtitle_014",
      "start": "00:00:51.933",
      "end": "00:00:53.666",
      "text": "毅力当然是"
    },
    {
      "id": "subtitle_015",
      "start": "00:00:53.666",
      "end": "00:00:55.933",
      "text": "不是第一个访问火星的漫游者"
    },
    {
      "id": "subtitle_016",
      "start": "00:00:55.933",
      "end": "00:00:59.333",
      "text": "旅居者在1997年是一个非常小的漫游者"
    },
    {
      "id": "subtitle_017",
      "start": "00:00:59.333",
      "end": "00:01:01.533",
      "text": "这是一个比较尺寸的人。"
    },
    {
      "id": "subtitle_018",
      "start": "00:01:02.300",
      "end": "00:01:05.000",
      "text": "2004年的精神与机遇"
    },
    {
      "id": "subtitle_019",
      "start": "00:01:05.066",
      "end": "00:01:06.633",
      "text": "这些是一模一样的漫游者"
    },
    {
      "id": "subtitle_020",
      "start": "00:01:06.633",
      "end": "00:01:08.833",
      "text": "彼此相隔几周发送"
    },
    {
      "id": "subtitle_021",
      "start": "00:01:09.600",
      "end": "00:01:12.433",
      "text": "好奇心在2012年登陆"
    },
    {
      "id": "subtitle_022",
      "start": "00:01:13.033",
      "end": "00:01:15.733",
      "text": "然后在2021年坚持不懈"
    },
    {
      "id": "subtitle_023",
      "start": "00:01:15.733",
      "end": "00:01:17.300",
      "text": "和好奇心一样大"
    },
    {
      "id": "subtitle_024",
      "start": "00:01:17.300",
      "end": "00:01:19.400",
      "text": "但更先进的技术"
    },
    {
      "id": "subtitle_025",
      "start": "00:01:19.466",
      "end": "00:01:20.933",
      "text": "这不是一个完整的列表"
    },
    {
      "id": "subtitle_026",
      "start": "00:01:20.933",
      "end": "00:01:23.700",
      "text": "这只是美国航天局最近发送的漫游者"
    },
    {
      "id": "subtitle_027",
      "start": "00:01:23.700",
      "end": "00:01:25.033",
      "text": "在美国"
    },
    {
      "id": "subtitle_028",
      "start": "00:01:25.233",
      "end": "00:01:28.500",
      "text": "在这个视频的大部分时间里，我会把重点放在毅力上。"
    },
    {
      "id": "subtitle_029",
      "start": "00:01:30.466",
      "end": "00:01:33.400",
      "text": "美国航天局在帕萨迪纳设计和制造漫游者"
    },
    {
      "id": "subtitle_030",
      "start": "00:01:33.400",
      "end": "00:01:34.200",
      "text": "加利福尼亚州"
    },
    {
      "id": "subtitle_031",
      "start": "00:01:34.200",
      "end": "00:01:37.666",
      "text": "喷气推进实验室或简称喷气推进实验室"
    },
    {
      "id": "subtitle_032",
      "start": "00:01:38.333",
      "end": "00:01:40.600",
      "text": "这花了大约八年的设计时间"
    },
    {
      "id": "subtitle_033",
      "start": "00:01:40.600",
      "end": "00:01:44.000",
      "text": "建立和测试，让毅力做好准备"
    },
    {
      "id": "subtitle_034",
      "start": "00:01:44.200",
      "end": "00:01:45.866",
      "text": "它是在一个干净的房间里建造的"
    },
    {
      "id": "subtitle_035",
      "start": "00:01:45.866",
      "end": "00:01:48.500",
      "text": "没有灰尘或其他污染物"
    },
    {
      "id": "subtitle_036",
      "start": "00:01:48.533",
      "end": "00:01:50.500",
      "text": "它被设计成在另一个星球上工作"
    },
    {
      "id": "subtitle_037",
      "start": "00:01:50.500",
      "end": "00:01:52.900",
      "text": "不同的大气不同的重力"
    },
    {
      "id": "subtitle_038",
      "start": "00:01:52.900",
      "end": "00:01:55.200",
      "text": "最重要的是没有维修站"
    },
    {
      "id": "subtitle_039",
      "start": "00:01:55.266",
      "end": "00:01:56.233",
      "text": "它必须经过设计"
    },
    {
      "id": "subtitle_040",
      "start": "00:01:56.233",
      "end": "00:01:59.300",
      "text": "如此之好，以至于它可以自己持续数年"
    },
    {
      "id": "subtitle_041",
      "start": "00:01:59.800",
      "end": "00:02:00.600",
      "text": "除此之外"
    },
    {
      "id": "subtitle_042",
      "start": "00:02:00.600",
      "end": "00:02:02.400",
      "text": "它必须轻巧紧凑"
    },
    {
      "id": "subtitle_043",
      "start": "00:02:02.400",
      "end": "00:02:04.833",
      "text": "所以它可以安装在运载火箭内部"
    },
    {
      "id": "subtitle_044",
      "start": "00:02:06.866",
      "end": "00:02:08.233",
      "text": "一旦它准备好了"
    },
    {
      "id": "subtitle_045",
      "start": "00:02:08.233",
      "end": "00:02:10.733",
      "text": "漫游者被精心包装"
    },
    {
      "id": "subtitle_046",
      "start": "00:02:12.600",
      "end": "00:02:14.833",
      "text": "然后飞越美国"
    },
    {
      "id": "subtitle_047",
      "start": "00:02:14.833",
      "end": "00:02:16.100",
      "text": "到肯尼迪航天中心"
    },
    {
      "id": "subtitle_048",
      "start": "00:02:16.100",
      "end": "00:02:18.933",
      "text": "在佛罗里达州，这是发射发生的地方"
    },
    {
      "id": "subtitle_049",
      "start": "00:02:19.133",
      "end": "00:02:21.600",
      "text": "就是美国航天局发射火箭的地方"
    },
    {
      "id": "subtitle_050",
      "start": "00:02:21.600",
      "end": "00:02:23.133",
      "text": "自20世纪60年代以来"
    },
    {
      "id": "subtitle_051",
      "start": "00:02:25.033",
      "end": "00:02:26.533",
      "text": "毅力被安装"
    },
    {
      "id": "subtitle_052",
      "start": "00:02:26.533",
      "end": "00:02:28.333",
      "text": "以及其他几个组件"
    },
    {
      "id": "subtitle_053",
      "start": "00:02:28.333",
      "end": "00:02:30.600",
      "text": "一起去火星旅行"
    },
    {
      "id": "subtitle_054",
      "start": "00:02:30.633",
      "end": "00:02:32.300",
      "text": "我们将讨论这些作品中的每一件"
    },
    {
      "id": "subtitle_055",
      "start": "00:02:32.300",
      "end": "00:02:33.466",
      "text": "稍后在视频中"
    },
    {
      "id": "subtitle_056",
      "start": "00:02:33.833",
      "end": "00:02:36.633",
      "text": "这都是放在有效载荷整流罩内的"
    },
    {
      "id": "subtitle_057",
      "start": "00:02:38.333",
      "end": "00:02:39.833",
      "text": "然后被带到火箭上"
    },
    {
      "id": "subtitle_058",
      "start": "00:02:39.866",
      "end": "00:02:42.500",
      "text": "然后上升到最高处"
    },
    {
      "id": "subtitle_059",
      "start": "00:02:43.133",
      "end": "00:02:45.600",
      "text": "这枚火箭叫做阿特拉斯5号"
    },
    {
      "id": "subtitle_060",
      "start": "00:02:45.933",
      "end": "00:02:47.233",
      "text": "它是由一家名为"
    },
    {
      "id": "subtitle_061",
      "start": "00:02:47.233",
      "end": "00:02:49.000",
      "text": "联合发射联盟"
    },
    {
      "id": "subtitle_062",
      "start": "00:02:49.000",
      "end": "00:02:50.633",
      "text": "或简称ULA"
    },
    {
      "id": "subtitle_063",
      "start": "00:02:51.866",
      "end": "00:02:52.666",
      "text": "让我指出"
    },
    {
      "id": "subtitle_064",
      "start": "00:02:52.666",
      "end": "00:02:55.033",
      "text": "火星车实际上是颠倒的"
    },
    {
      "id": "subtitle_065",
      "start": "00:02:55.033",
      "end": "00:02:56.133",
      "text": "为了发射"
    },
    {
      "id": "subtitle_066",
      "start": "00:02:58.900",
      "end": "00:03:01.900",
      "text": "发射到火星的最佳时间大约是每"
    },
    {
      "id": "subtitle_067",
      "start": "00:03:01.933",
      "end": "00:03:05.633",
      "text": "如果我们用正确的比例显示这个，26个月"
    },
    {
      "id": "subtitle_068",
      "start": "00:03:05.733",
      "end": "00:03:07.833",
      "text": "你几乎看不到太阳"
    },
    {
      "id": "subtitle_069",
      "start": "00:03:09.100",
      "end": "00:03:09.933",
      "text": "对于这个动画"
    },
    {
      "id": "subtitle_070",
      "start": "00:03:09.933",
      "end": "00:03:10.733",
      "text": "我来展示一下"
    },
    {
      "id": "subtitle_071",
      "start": "00:03:10.733",
      "end": "00:03:13.066",
      "text": "规模过大，这样我们可以更好地看到这个。"
    },
    {
      "id": "subtitle_072",
      "start": "00:03:13.633",
      "end": "00:03:15.233",
      "text": "地球绕着太阳转"
    },
    {
      "id": "subtitle_073",
      "start": "00:03:15.233",
      "end": "00:03:17.500",
      "text": "正好需要一年，对吧？"
    },
    {
      "id": "subtitle_074",
      "start": "00:03:17.500",
      "end": "00:03:18.866",
      "text": "那里没有惊喜"
    },
    {
      "id": "subtitle_075",
      "start": "00:03:19.266",
      "end": "00:03:20.466",
      "text": "另一方面，火星。"
    },
    {
      "id": "subtitle_076",
      "start": "00:03:20.466",
      "end": "00:03:23.200",
      "text": "绕着太阳转几乎要两年"
    },
    {
      "id": "subtitle_077",
      "start": "00:03:23.266",
      "end": "00:03:25.300",
      "text": "发射的最佳时间就在之前"
    },
    {
      "id": "subtitle_078",
      "start": "00:03:25.300",
      "end": "00:03:27.300",
      "text": "地球和火星是这样排列的"
    },
    {
      "id": "subtitle_079",
      "start": "00:03:27.300",
      "end": "00:03:30.466",
      "text": "被称为启动窗口，它发生在每个"
    },
    {
      "id": "subtitle_080",
      "start": "00:03:30.500",
      "end": "00:03:31.700",
      "text": "26个月"
    },
    {
      "id": "subtitle_081",
      "start": "00:03:33.200",
      "end": "00:03:36.900",
      "text": "毅力于2020年7月推出"
    },
    {
      "id": "subtitle_082",
      "start": "00:03:45.600",
      "end": "00:03:48.200",
      "text": "四个固体火箭助推器耗尽了所有燃料"
    },
    {
      "id": "subtitle_083",
      "start": "00:03:48.200",
      "end": "00:03:49.066",
      "text": "第一"
    },
    {
      "id": "subtitle_084",
      "start": "00:03:50.633",
      "end": "00:03:52.400",
      "text": "1分49秒"
    },
    {
      "id": "subtitle_085",
      "start": "00:03:52.400",
      "end": "00:03:55.066",
      "text": "它们被抛弃或与火箭分离"
    },
    {
      "id": "subtitle_086",
      "start": "00:03:59.066",
      "end": "00:04:00.900",
      "text": "3分27秒"
    },
    {
      "id": "subtitle_087",
      "start": "00:04:00.900",
      "end": "00:04:02.533",
      "text": "有效载荷整流罩被丢弃"
    },
    {
      "id": "subtitle_088",
      "start": "00:04:02.533",
      "end": "00:04:04.633",
      "text": "这暴露了飞船"
    },
    {
      "id": "subtitle_089",
      "start": "00:04:07.266",
      "end": "00:04:09.733",
      "text": "接下来主助推器燃料耗尽"
    },
    {
      "id": "subtitle_090",
      "start": "00:04:09.733",
      "end": "00:04:13.233",
      "text": "4分28秒主助推器分离"
    },
    {
      "id": "subtitle_091",
      "start": "00:04:13.233",
      "end": "00:04:15.000",
      "text": "它会落回地球"
    },
    {
      "id": "subtitle_092",
      "start": "00:04:16.266",
      "end": "00:04:18.233",
      "text": "这叫半人马座阶段"
    },
    {
      "id": "subtitle_093",
      "start": "00:04:18.433",
      "end": "00:04:20.266",
      "text": "它的主引擎现在启动了"
    },
    {
      "id": "subtitle_094",
      "start": "00:04:21.900",
      "end": "00:04:24.466",
      "text": "这就是让我们进入绕地球轨道的原因"
    },
    {
      "id": "subtitle_095",
      "start": "00:04:25.466",
      "end": "00:04:28.733",
      "text": "11分30秒时引擎熄火"
    },
    {
      "id": "subtitle_096",
      "start": "00:04:29.300",
      "end": "00:04:31.333",
      "text": "这就是所谓的海岸阶段"
    },
    {
      "id": "subtitle_097",
      "start": "00:04:31.800",
      "end": "00:04:33.666",
      "text": "我们会在这里呆半个小时"
    },
    {
      "id": "subtitle_098",
      "start": "00:04:33.666",
      "end": "00:04:35.100",
      "text": "这是检查东西的好时机"
    },
    {
      "id": "subtitle_099",
      "start": "00:04:35.100",
      "end": "00:04:37.300",
      "text": "并确保一切正常。"
    },
    {
      "id": "subtitle_100",
      "start": "00:04:37.300",
      "end": "00:04:38.200",
      "text": "理所应当"
    },
    {
      "id": "subtitle_101",
      "start": "00:04:39.233",
      "end": "00:04:42.400",
      "text": "然后我们重新点燃引擎大约八分钟"
    },
    {
      "id": "subtitle_102",
      "start": "00:04:42.400",
      "end": "00:04:44.666",
      "text": "这就是所谓的地球逃生燃烧"
    },
    {
      "id": "subtitle_103",
      "start": "00:04:45.533",
      "end": "00:04:48.100",
      "text": "这让我们踏上了通往火星的道路"
    },
    {
      "id": "subtitle_104",
      "start": "00:04:49.133",
      "end": "00:04:51.133",
      "text": "然后飞船分离"
    },
    {
      "id": "subtitle_105",
      "start": "00:04:52.433",
      "end": "00:04:55.733",
      "text": "它以每小时41000公里的速度飞行"
    },
    {
      "id": "subtitle_106",
      "start": "00:04:57.000",
      "end": "00:05:00.066",
      "text": "大约需要七个月才能到达火星。"
    },
    {
      "id": "subtitle_107",
      "start": "00:05:05.266",
      "end": "00:05:08.200",
      "text": "我们的飞船由几块组成"
    },
    {
      "id": "subtitle_108",
      "start": "00:05:08.700",
      "end": "00:05:12.600",
      "text": "这是火星车在降落阶段折叠起来的样子"
    },
    {
      "id": "subtitle_109",
      "start": "00:05:12.600",
      "end": "00:05:14.600",
      "text": "这上面有八个火箭引擎"
    },
    {
      "id": "subtitle_110",
      "start": "00:05:14.600",
      "end": "00:05:15.500",
      "text": "隔热罩"
    },
    {
      "id": "subtitle_111",
      "start": "00:05:15.500",
      "end": "00:05:17.233",
      "text": "这会减慢我们在大气层中的速度"
    },
    {
      "id": "subtitle_112",
      "start": "00:05:17.233",
      "end": "00:05:18.600",
      "text": "并保护漫游者"
    },
    {
      "id": "subtitle_113",
      "start": "00:05:18.600",
      "end": "00:05:19.500",
      "text": "后壳"
    },
    {
      "id": "subtitle_114",
      "start": "00:05:19.500",
      "end": "00:05:20.400",
      "text": "保护漫游者"
    },
    {
      "id": "subtitle_115",
      "start": "00:05:20.400",
      "end": "00:05:21.900",
      "text": "当它下降到表面时"
    },
    {
      "id": "subtitle_116",
      "start": "00:05:21.900",
      "end": "00:05:25.433",
      "text": "火星这是巡航级提供动力"
    },
    {
      "id": "subtitle_117",
      "start": "00:05:25.433",
      "end": "00:05:27.066",
      "text": "油箱和推进器"
    },
    {
      "id": "subtitle_118",
      "start": "00:05:27.066",
      "end": "00:05:29.400",
      "text": "并与地球保持联系"
    },
    {
      "id": "subtitle_119",
      "start": "00:05:30.333",
      "end": "00:05:32.133",
      "text": "整个集会都在一起"
    },
    {
      "id": "subtitle_120",
      "start": "00:05:32.133",
      "end": "00:05:34.666",
      "text": "在七个月的火星之旅中"
    },
    {
      "id": "subtitle_121",
      "start": "00:05:36.000",
      "end": "00:05:38.400",
      "text": "一路上我们需要调整路线"
    },
    {
      "id": "subtitle_122",
      "start": "00:05:39.266",
      "end": "00:05:40.833",
      "text": "我们用推进器来做这个"
    },
    {
      "id": "subtitle_123",
      "start": "00:05:40.833",
      "end": "00:05:42.733",
      "text": "在游轮舞台的一侧"
    },
    {
      "id": "subtitle_124",
      "start": "00:05:46.600",
      "end": "00:05:50.433",
      "text": "这叫做弹道修正机动或TCM"
    },
    {
      "id": "subtitle_125",
      "start": "00:05:50.433",
      "end": "00:05:53.333",
      "text": "其中有几个正在去火星的路上。"
    },
    {
      "id": "subtitle_126",
      "start": "00:06:02.933",
      "end": "00:06:04.633",
      "text": "登陆火星表面"
    },
    {
      "id": "subtitle_127",
      "start": "00:06:04.633",
      "end": "00:06:06.333",
      "text": "简直就是激烈"
    },
    {
      "id": "subtitle_128",
      "start": "00:06:06.333",
      "end": "00:06:09.700",
      "text": "他们称之为EDL或入口下降和着陆"
    },
    {
      "id": "subtitle_129",
      "start": "00:06:09.933",
      "end": "00:06:12.600",
      "text": "常被戏称为恐怖的7分钟"
    },
    {
      "id": "subtitle_130",
      "start": "00:06:12.600",
      "end": "00:06:14.600",
      "text": "这是因为如果出了什么差错"
    },
    {
      "id": "subtitle_131",
      "start": "00:06:14.600",
      "end": "00:06:16.600",
      "text": "那我们可能就拿不到火星车了"
    },
    {
      "id": "subtitle_132",
      "start": "00:06:16.600",
      "end": "00:06:18.133",
      "text": "安全着陆"
    },
    {
      "id": "subtitle_133",
      "start": "00:06:19.266",
      "end": "00:06:20.333",
      "text": "着陆时"
    },
    {
      "id": "subtitle_134",
      "start": "00:06:20.333",
      "end": "00:06:21.900",
      "text": "大约需要11分钟"
    },
    {
      "id": "subtitle_135",
      "start": "00:06:21.900",
      "end": "00:06:23.900",
      "text": "任何信号到达地球"
    },
    {
      "id": "subtitle_136",
      "start": "00:06:23.900",
      "end": "00:06:26.333",
      "text": "这当然是以光速旅行"
    },
    {
      "id": "subtitle_137",
      "start": "00:06:26.333",
      "end": "00:06:28.533",
      "text": "我们知道如何最快地交流"
    },
    {
      "id": "subtitle_138",
      "start": "00:06:31.600",
      "end": "00:06:33.800",
      "text": "它看起来不是很快，是吗？"
    },
    {
      "id": "subtitle_139",
      "start": "00:06:33.933",
      "end": "00:06:36.000",
      "text": "11分钟是很长的一段时间"
    },
    {
      "id": "subtitle_140",
      "start": "00:06:36.033",
      "end": "00:06:38.800",
      "text": "从地球到月球的角度来看"
    },
    {
      "id": "subtitle_141",
      "start": "00:06:38.800",
      "end": "00:06:41.633",
      "text": "光只需要1秒钟多一点就可以到达那里"
    },
    {
      "id": "subtitle_142",
      "start": "00:06:43.666",
      "end": "00:06:46.133",
      "text": "当Apollo宇航员登陆月球时"
    },
    {
      "id": "subtitle_143",
      "start": "00:06:46.133",
      "end": "00:06:49.400",
      "text": "美国航天局几乎可以与他们实时通信"
    },
    {
      "id": "subtitle_144",
      "start": "00:06:49.433",
      "end": "00:06:51.300",
      "text": "大约需要2.5秒。"
    },
    {
      "id": "subtitle_145",
      "start": "00:06:51.300",
      "end": "00:06:52.733",
      "text": "收到回复"
    },
    {
      "id": "subtitle_146",
      "start": "00:06:54.733",
      "end": "00:06:56.633",
      "text": "在火星上这完全是"
    },
    {
      "id": "subtitle_147",
      "start": "00:06:57.233",
      "end": "00:06:59.200",
      "text": "如果着陆时出了什么问题"
    },
    {
      "id": "subtitle_148",
      "start": "00:06:59.200",
      "end": "00:07:02.433",
      "text": "任务控制中心11分钟内不会收到消息"
    },
    {
      "id": "subtitle_149",
      "start": "00:07:02.633",
      "end": "00:07:05.466",
      "text": "任何回复都需要11分钟才能得到。"
    },
    {
      "id": "subtitle_150",
      "start": "00:07:05.466",
      "end": "00:07:06.633",
      "text": "一路回来"
    },
    {
      "id": "subtitle_151",
      "start": "00:07:07.400",
      "end": "00:07:09.666",
      "text": "到这时它已经结束了"
    },
    {
      "id": "subtitle_152",
      "start": "00:07:09.833",
      "end": "00:07:12.433",
      "text": "不是安全着陆就是坠机"
    },
    {
      "id": "subtitle_153",
      "start": "00:07:12.866",
      "end": "00:07:14.233",
      "text": "这意味着电脑"
    },
    {
      "id": "subtitle_154",
      "start": "00:07:14.233",
      "end": "00:07:15.733",
      "text": "电子和软件"
    },
    {
      "id": "subtitle_155",
      "start": "00:07:15.733",
      "end": "00:07:18.800",
      "text": "必须足够聪明，可以自己做任何事情"
    },
    {
      "id": "subtitle_156",
      "start": "00:07:19.466",
      "end": "00:07:21.933",
      "text": "EDL入口下降和着陆"
    },
    {
      "id": "subtitle_157",
      "start": "00:07:21.933",
      "end": "00:07:24.000",
      "text": "让我们一步一步来"
    },
    {
      "id": "subtitle_158",
      "start": "00:07:24.133",
      "end": "00:07:26.800",
      "text": "大约在进入大气层前10分钟"
    },
    {
      "id": "subtitle_159",
      "start": "00:07:26.800",
      "end": "00:07:27.733",
      "text": "巡航阶段"
    },
    {
      "id": "subtitle_160",
      "start": "00:07:27.733",
      "end": "00:07:29.933",
      "text": "是分离的，因为它不再需要了。"
    },
    {
      "id": "subtitle_161",
      "start": "00:07:33.600",
      "end": "00:07:35.233",
      "text": "后壳上的小型推进器"
    },
    {
      "id": "subtitle_162",
      "start": "00:07:35.233",
      "end": "00:07:37.833",
      "text": "将被用来操纵飞船"
    },
    {
      "id": "subtitle_163",
      "start": "00:07:39.000",
      "end": "00:07:41.266",
      "text": "接下来是大气进入"
    },
    {
      "id": "subtitle_164",
      "start": "00:07:41.266",
      "end": "00:07:44.400",
      "text": "在这段时间里隔热罩会保护漫游者"
    },
    {
      "id": "subtitle_165",
      "start": "00:07:54.266",
      "end": "00:07:57.066",
      "text": "一旦我们到达离地面11公里的地方"
    },
    {
      "id": "subtitle_166",
      "start": "00:07:57.066",
      "end": "00:07:58.900",
      "text": "然后降落伞就可以展开了"
    },
    {
      "id": "subtitle_167",
      "start": "00:07:59.266",
      "end": "00:08:01.800",
      "text": "它使用一种称为范围触发的技术"
    },
    {
      "id": "subtitle_168",
      "start": "00:08:01.800",
      "end": "00:08:04.400",
      "text": "它会发现我们离着陆点有多近"
    },
    {
      "id": "subtitle_169",
      "start": "00:08:04.400",
      "end": "00:08:05.933",
      "text": "然后打开降落伞"
    },
    {
      "id": "subtitle_170",
      "start": "00:08:05.933",
      "end": "00:08:07.500",
      "text": "在适当的时候"
    },
    {
      "id": "subtitle_171",
      "start": "00:08:11.666",
      "end": "00:08:14.133",
      "text": "下一步是隔热罩分离"
    },
    {
      "id": "subtitle_172",
      "start": "00:08:15.533",
      "end": "00:08:16.433",
      "text": "第一次"
    },
    {
      "id": "subtitle_173",
      "start": "00:08:16.433",
      "end": "00:08:19.233",
      "text": "毅力漫游者现在可以看到火星表面了"
    },
    {
      "id": "subtitle_174",
      "start": "00:08:19.233",
      "end": "00:08:20.066",
      "text": "下面"
    },
    {
      "id": "subtitle_175",
      "start": "00:08:21.000",
      "end": "00:08:23.466",
      "text": "现在我们使用地形相对导航"
    },
    {
      "id": "subtitle_176",
      "start": "00:08:23.466",
      "end": "00:08:26.133",
      "text": "漫游者将拍摄下面的地面"
    },
    {
      "id": "subtitle_177",
      "start": "00:08:26.133",
      "end": "00:08:28.666",
      "text": "并将这些与火星地图进行比较"
    },
    {
      "id": "subtitle_178",
      "start": "00:08:28.666",
      "end": "00:08:31.033",
      "text": "这将用于安全驾驶漫游者"
    },
    {
      "id": "subtitle_179",
      "start": "00:08:31.033",
      "end": "00:08:33.000",
      "text": "朝着预定的着陆点"
    },
    {
      "id": "subtitle_180",
      "start": "00:08:34.000",
      "end": "00:08:36.300",
      "text": "接下来是后壳分离"
    },
    {
      "id": "subtitle_181",
      "start": "00:08:37.466",
      "end": "00:08:40.400",
      "text": "剩下的就是降落台和漫游者了"
    },
    {
      "id": "subtitle_182",
      "start": "00:08:42.500",
      "end": "00:08:44.433",
      "text": "火箭在下降阶段发射"
    },
    {
      "id": "subtitle_183",
      "start": "00:08:44.433",
      "end": "00:08:45.466",
      "text": "让我们慢下来"
    },
    {
      "id": "subtitle_184",
      "start": "00:08:45.466",
      "end": "00:08:47.500",
      "text": "当我们接近地表"
    },
    {
      "id": "subtitle_185",
      "start": "00:08:50.600",
      "end": "00:08:51.933",
      "text": "然后漫游者分离"
    },
    {
      "id": "subtitle_186",
      "start": "00:08:51.933",
      "end": "00:08:54.100",
      "text": "但仍然由一些电缆连接"
    },
    {
      "id": "subtitle_187",
      "start": "00:08:54.100",
      "end": "00:08:56.466",
      "text": "他们称之为空中吊车机动"
    },
    {
      "id": "subtitle_188",
      "start": "00:08:57.466",
      "end": "00:09:00.600",
      "text": "最后一部分每个人都在等待触地得分"
    },
    {
      "id": "subtitle_189",
      "start": "00:09:01.666",
      "end": "00:09:02.666",
      "text": "电缆被切断了"
    },
    {
      "id": "subtitle_190",
      "start": "00:09:02.666",
      "end": "00:09:03.633",
      "text": "和下降阶段"
    },
    {
      "id": "subtitle_191",
      "start": "00:09:03.633",
      "end": "00:09:06.066",
      "text": "飞向远方迫降"
    },
    {
      "id": "subtitle_192",
      "start": "00:09:06.066",
      "end": "00:09:07.666",
      "text": "远离漫游者"
    },
    {
      "id": "subtitle_193",
      "start": "00:09:08.266",
      "end": "00:09:10.733",
      "text": "现在是时候检查漫游者的系统了"
    },
    {
      "id": "subtitle_194",
      "start": "00:09:11.033",
      "end": "00:09:12.500",
      "text": "展开桅杆"
    },
    {
      "id": "subtitle_195",
      "start": "00:09:13.000",
      "end": "00:09:15.700",
      "text": "然后是最前面的机械臂"
    },
    {
      "id": "subtitle_196",
      "start": "00:09:15.866",
      "end": "00:09:18.066",
      "text": "毅力罗孚的主要目的"
    },
    {
      "id": "subtitle_197",
      "start": "00:09:18.066",
      "end": "00:09:19.900",
      "text": "就是寻找生命的迹象"
    },
    {
      "id": "subtitle_198",
      "start": "00:09:20.233",
      "end": "00:09:21.733",
      "text": "它降落在Jezreel陨石坑"
    },
    {
      "id": "subtitle_199",
      "start": "00:09:21.733",
      "end": "00:09:22.333",
      "text": "哪个"
    },
    {
      "id": "subtitle_200",
      "start": "00:09:22.333",
      "end": "00:09:25.033",
      "text": "数十亿年前这里曾经充满了水"
    },
    {
      "id": "subtitle_201",
      "start": "00:09:25.033",
      "end": "00:09:25.933",
      "text": "有水的地方"
    },
    {
      "id": "subtitle_202",
      "start": "00:09:25.933",
      "end": "00:09:27.333",
      "text": "通常有生命"
    },
    {
      "id": "subtitle_203",
      "start": "00:09:27.333",
      "end": "00:09:30.466",
      "text": "或者至少是过去存在生命的迹象"
    },
    {
      "id": "subtitle_204",
      "start": "00:09:30.933",
      "end": "00:09:33.200",
      "text": "毅力漫游者有一系列先进的"
    },
    {
      "id": "subtitle_205",
      "start": "00:09:33.200",
      "end": "00:09:36.400",
      "text": "研究火星表面的科学仪器"
    },
    {
      "id": "subtitle_206",
      "start": "00:09:36.500",
      "end": "00:09:39.500",
      "text": "如果你还记得之前的火星车是巨大的"
    },
    {
      "id": "subtitle_207",
      "start": "00:09:39.500",
      "end": "00:09:41.133",
      "text": "大概有一辆车那么大"
    },
    {
      "id": "subtitle_208",
      "start": "00:09:42.000",
      "end": "00:09:44.533",
      "text": "漫游者的主体他们称之为网络"
    },
    {
      "id": "subtitle_209",
      "start": "00:09:44.633",
      "end": "00:09:46.500",
      "text": "保暖电子盒"
    },
    {
      "id": "subtitle_210",
      "start": "00:09:47.233",
      "end": "00:09:48.700",
      "text": "那你就有六个轮子了"
    },
    {
      "id": "subtitle_211",
      "start": "00:09:48.700",
      "end": "00:09:51.133",
      "text": "两边各三个是铝制的"
    },
    {
      "id": "subtitle_212",
      "start": "00:09:51.600",
      "end": "00:09:53.733",
      "text": "前后轮都能转"
    },
    {
      "id": "subtitle_213",
      "start": "00:09:53.933",
      "end": "00:09:57.400",
      "text": "让漫游者旋转整整360度"
    },
    {
      "id": "subtitle_214",
      "start": "00:09:59.500",
      "end": "00:10:00.733",
      "text": "悬挂系统"
    },
    {
      "id": "subtitle_215",
      "start": "00:10:00.733",
      "end": "00:10:03.533",
      "text": "可以让漫游者在崎岖的地形上行驶"
    },
    {
      "id": "subtitle_216",
      "start": "00:10:03.700",
      "end": "00:10:05.400",
      "text": "你永远不知道什么样的障碍"
    },
    {
      "id": "subtitle_217",
      "start": "00:10:05.400",
      "end": "00:10:07.433",
      "text": "你会在火星上遇到"
    },
    {
      "id": "subtitle_218",
      "start": "00:10:09.000",
      "end": "00:10:10.533",
      "text": "但更现实一点"
    },
    {
      "id": "subtitle_219",
      "start": "00:10:10.533",
      "end": "00:10:13.266",
      "text": "漫游者会开得这么快"
    },
    {
      "id": "subtitle_220",
      "start": "00:10:14.200",
      "end": "00:10:17.433",
      "text": "它的最高时速为01公里"
    },
    {
      "id": "subtitle_221",
      "start": "00:10:17.433",
      "end": "00:10:19.533",
      "text": "速度慢主要是为了安全"
    },
    {
      "id": "subtitle_222",
      "start": "00:10:19.533",
      "end": "00:10:21.266",
      "text": "和漫游者的稳定性"
    },
    {
      "id": "subtitle_223",
      "start": "00:10:22.333",
      "end": "00:10:24.300",
      "text": "这是遥感桅杆"
    },
    {
      "id": "subtitle_224",
      "start": "00:10:24.300",
      "end": "00:10:26.700",
      "text": "这是你能找到一些摄像机的地方"
    },
    {
      "id": "subtitle_225",
      "start": "00:10:26.700",
      "end": "00:10:28.233",
      "text": "和漫游者的传感器"
    },
    {
      "id": "subtitle_226",
      "start": "00:10:28.433",
      "end": "00:10:30.800",
      "text": "只是比人类的身高高一点"
    },
    {
      "id": "subtitle_227",
      "start": "00:10:31.133",
      "end": "00:10:31.933",
      "text": "想法是"
    },
    {
      "id": "subtitle_228",
      "start": "00:10:31.933",
      "end": "00:10:34.800",
      "text": "让我们对一个人会看到什么有类似的看法"
    },
    {
      "id": "subtitle_229",
      "start": "00:10:34.800",
      "end": "00:10:35.733",
      "text": "如果他们在这里"
    },
    {
      "id": "subtitle_230",
      "start": "00:10:35.733",
      "end": "00:10:36.633",
      "text": "在火星上"
    },
    {
      "id": "subtitle_231",
      "start": "00:10:37.133",
      "end": "00:10:39.933",
      "text": "最上面的这个大圆圈叫作超级圆环。"
    },
    {
      "id": "subtitle_232",
      "start": "00:10:40.233",
      "end": "00:10:42.633",
      "text": "它基本上是一种激光，可以识别化学物质"
    },
    {
      "id": "subtitle_233",
      "start": "00:10:42.633",
      "end": "00:10:45.233",
      "text": "在7米外的岩石中"
    },
    {
      "id": "subtitle_234",
      "start": "00:10:46.666",
      "end": "00:10:48.333",
      "text": "这是Mastcam Z"
    },
    {
      "id": "subtitle_235",
      "start": "00:10:48.333",
      "end": "00:10:50.066",
      "text": "这些是探测器的主摄像头"
    },
    {
      "id": "subtitle_236",
      "start": "00:10:50.066",
      "end": "00:10:52.433",
      "text": "甚至可以拍摄高清视频"
    },
    {
      "id": "subtitle_237",
      "start": "00:10:53.200",
      "end": "00:10:53.800",
      "text": "导航"
    },
    {
      "id": "subtitle_238",
      "start": "00:10:53.800",
      "end": "00:10:56.233",
      "text": "摄像头是用来帮助漫游者安全行驶的"
    },
    {
      "id": "subtitle_239",
      "start": "00:10:56.233",
      "end": "00:10:57.666",
      "text": "在火星表面"
    },
    {
      "id": "subtitle_240",
      "start": "00:10:57.833",
      "end": "00:11:01.300",
      "text": "正下方是火星环境动力学分析仪"
    },
    {
      "id": "subtitle_241",
      "start": "00:11:01.300",
      "end": "00:11:02.100",
      "text": "或元"
    },
    {
      "id": "subtitle_242",
      "start": "00:11:02.100",
      "end": "00:11:05.100",
      "text": "这是在研究火星上的天气和大气层"
    },
    {
      "id": "subtitle_243",
      "start": "00:11:05.733",
      "end": "00:11:08.666",
      "text": "漫游者有两个麦克风，一个在桅杆上"
    },
    {
      "id": "subtitle_244",
      "start": "00:11:10.133",
      "end": "00:11:12.266",
      "text": "然后另一个在漫游者的侧面"
    },
    {
      "id": "subtitle_245",
      "start": "00:11:14.200",
      "end": "00:11:15.866",
      "text": "然后我们有hascams"
    },
    {
      "id": "subtitle_246",
      "start": "00:11:15.866",
      "end": "00:11:17.900",
      "text": "这是危险摄像头的缩写"
    },
    {
      "id": "subtitle_247",
      "start": "00:11:17.900",
      "end": "00:11:19.433",
      "text": "前面有一些"
    },
    {
      "id": "subtitle_248",
      "start": "00:11:19.700",
      "end": "00:11:21.300",
      "text": "但也在后面"
    },
    {
      "id": "subtitle_249",
      "start": "00:11:21.300",
      "end": "00:11:22.600",
      "text": "就像名字说的"
    },
    {
      "id": "subtitle_250",
      "start": "00:11:22.600",
      "end": "00:11:25.433",
      "text": "这些摄像头有助于避免危险和障碍物"
    },
    {
      "id": "subtitle_251",
      "start": "00:11:25.433",
      "end": "00:11:27.333",
      "text": "在火星上开车时"
    },
    {
      "id": "subtitle_252",
      "start": "00:11:27.866",
      "end": "00:11:29.733",
      "text": "漫游者的电源称为"
    },
    {
      "id": "subtitle_253",
      "start": "00:11:29.733",
      "end": "00:11:30.933",
      "text": "放射性同位素"
    },
    {
      "id": "subtitle_254",
      "start": "00:11:30.933",
      "end": "00:11:32.633",
      "text": "热电发电机"
    },
    {
      "id": "subtitle_255",
      "start": "00:11:32.633",
      "end": "00:11:34.266",
      "text": "或简称RTG"
    },
    {
      "id": "subtitle_256",
      "start": "00:11:34.266",
      "end": "00:11:35.833",
      "text": "这是一个核动力源"
    },
    {
      "id": "subtitle_257",
      "start": "00:11:35.833",
      "end": "00:11:38.533",
      "text": "放射性元素的衰变产生热量"
    },
    {
      "id": "subtitle_258",
      "start": "00:11:38.533",
      "end": "00:11:40.733",
      "text": "然后可以转化为电能"
    },
    {
      "id": "subtitle_259",
      "start": "00:11:41.833",
      "end": "00:11:44.633",
      "text": "以前的一些漫游者使用太阳能电池板"
    },
    {
      "id": "subtitle_260",
      "start": "00:11:44.633",
      "end": "00:11:46.500",
      "text": "利用阳光发电"
    },
    {
      "id": "subtitle_261",
      "start": "00:11:46.500",
      "end": "00:11:47.866",
      "text": "但这在晚上不起作用"
    },
    {
      "id": "subtitle_262",
      "start": "00:11:47.866",
      "end": "00:11:49.666",
      "text": "如果上面有太多灰尘"
    },
    {
      "id": "subtitle_263",
      "start": "00:11:49.666",
      "end": "00:11:51.333",
      "text": "那么游戏结束了"
    },
    {
      "id": "subtitle_264",
      "start": "00:11:51.600",
      "end": "00:11:54.733",
      "text": "好奇心和毅力都使用了RTG"
    },
    {
      "id": "subtitle_265",
      "start": "00:11:54.733",
      "end": "00:11:58.033",
      "text": "这意味着在权力方面有更多的灵活性"
    },
    {
      "id": "subtitle_266",
      "start": "00:11:59.700",
      "end": "00:12:00.500",
      "text": "这是"
    },
    {
      "id": "subtitle_267",
      "start": "00:12:00.500",
      "end": "00:12:04.700",
      "text": "用于火星地下实验的rimpax或雷达成像仪"
    },
    {
      "id": "subtitle_268",
      "start": "00:12:04.700",
      "end": "00:12:07.233",
      "text": "这是利用雷达波来研究地面"
    },
    {
      "id": "subtitle_269",
      "start": "00:12:07.233",
      "end": "00:12:10.300",
      "text": "在火星表面以下9米处"
    },
    {
      "id": "subtitle_270",
      "start": "00:12:11.233",
      "end": "00:12:12.633",
      "text": "还有莫邪"
    },
    {
      "id": "subtitle_271",
      "start": "00:12:12.633",
      "end": "00:12:16.200",
      "text": "火星氧原位资源利用实验"
    },
    {
      "id": "subtitle_272",
      "start": "00:12:16.200",
      "end": "00:12:18.200",
      "text": "这把火星上的二氧化碳"
    },
    {
      "id": "subtitle_273",
      "start": "00:12:18.200",
      "end": "00:12:19.900",
      "text": "并将其转化为氧气"
    },
    {
      "id": "subtitle_274",
      "start": "00:12:19.900",
      "end": "00:12:22.400",
      "text": "这种技术将非常重要"
    },
    {
      "id": "subtitle_275",
      "start": "00:12:22.400",
      "end": "00:12:24.833",
      "text": "一旦我们开始把人类送上火星"
    },
    {
      "id": "subtitle_276",
      "start": "00:12:25.633",
      "end": "00:12:26.400",
      "text": "当然还有"
    },
    {
      "id": "subtitle_277",
      "start": "00:12:26.400",
      "end": "00:12:29.133",
      "text": "漫游者最前面的机械臂"
    },
    {
      "id": "subtitle_278",
      "start": "00:12:29.133",
      "end": "00:12:30.300",
      "text": "这有几个工具"
    },
    {
      "id": "subtitle_279",
      "start": "00:12:30.300",
      "end": "00:12:32.833",
      "text": "最后是美国航天局的缩写"
    },
    {
      "id": "subtitle_280",
      "start": "00:12:32.833",
      "end": "00:12:34.833",
      "text": "所以我们开始吧Pixel"
    },
    {
      "id": "subtitle_281",
      "start": "00:12:34.833",
      "end": "00:12:35.000",
      "text": "这"
    },
    {
      "id": "subtitle_282",
      "start": "00:12:35.000",
      "end": "00:12:37.600",
      "text": "有助于确定构成岩石的化学物质"
    },
    {
      "id": "subtitle_283",
      "start": "00:12:37.600",
      "end": "00:12:39.266",
      "text": "在非常小的范围内"
    },
    {
      "id": "subtitle_284",
      "start": "00:12:41.133",
      "end": "00:12:43.233",
      "text": "沃森另一个强大的相机"
    },
    {
      "id": "subtitle_285",
      "start": "00:12:43.233",
      "end": "00:12:45.433",
      "text": "仔细观察岩石"
    },
    {
      "id": "subtitle_286",
      "start": "00:12:47.000",
      "end": "00:12:50.300",
      "text": "然后夏洛克这个提供了精细的成像"
    },
    {
      "id": "subtitle_287",
      "start": "00:12:51.833",
      "end": "00:12:54.600",
      "text": "臂的末端是取心钻"
    },
    {
      "id": "subtitle_288",
      "start": "00:12:54.933",
      "end": "00:12:57.700",
      "text": "这能够钻探和收集样本"
    },
    {
      "id": "subtitle_289",
      "start": "00:12:57.700",
      "end": "00:12:58.666",
      "text": "那将被存储"
    },
    {
      "id": "subtitle_290",
      "start": "00:12:58.666",
      "end": "00:13:00.100",
      "text": "在漫游者上"
    },
    {
      "id": "subtitle_291",
      "start": "00:13:05.233",
      "end": "00:13:07.300",
      "text": "然后它会采集这些样本并放置它们"
    },
    {
      "id": "subtitle_292",
      "start": "00:13:07.300",
      "end": "00:13:09.000",
      "text": "漫游者内部"
    },
    {
      "id": "subtitle_293",
      "start": "00:13:09.333",
      "end": "00:13:10.533",
      "text": "未来的任务已计划好"
    },
    {
      "id": "subtitle_294",
      "start": "00:13:10.533",
      "end": "00:13:12.700",
      "text": "从火星表面采集这些样本"
    },
    {
      "id": "subtitle_295",
      "start": "00:13:12.700",
      "end": "00:13:15.666",
      "text": "并将它们送回地球以便我们进一步研究它们"
    },
    {
      "id": "subtitle_296",
      "start": "00:13:16.900",
      "end": "00:13:19.866",
      "text": "那么毅力是如何与地球沟通的呢？"
    },
    {
      "id": "subtitle_297",
      "start": "00:13:19.866",
      "end": "00:13:22.833",
      "text": "最好的办法是使用火星中继网络"
    },
    {
      "id": "subtitle_298",
      "start": "00:13:22.833",
      "end": "00:13:24.900",
      "text": "它由几颗卫星组成"
    },
    {
      "id": "subtitle_299",
      "start": "00:13:24.900",
      "end": "00:13:26.466",
      "text": "环绕火星的轨道"
    },
    {
      "id": "subtitle_300",
      "start": "00:13:27.066",
      "end": "00:13:28.600",
      "text": "这些是很久以前推出的"
    },
    {
      "id": "subtitle_301",
      "start": "00:13:28.600",
      "end": "00:13:30.300",
      "text": "毅力到达火星"
    },
    {
      "id": "subtitle_302",
      "start": "00:13:30.433",
      "end": "00:13:32.800",
      "text": "这些卫星也用于科学研究"
    },
    {
      "id": "subtitle_303",
      "start": "00:13:32.800",
      "end": "00:13:34.466",
      "text": "并与其他漫游者交流"
    },
    {
      "id": "subtitle_304",
      "start": "00:13:34.466",
      "end": "00:13:36.100",
      "text": "也在火星上"
    },
    {
      "id": "subtitle_305",
      "start": "00:13:36.333",
      "end": "00:13:37.233",
      "text": "例如其中一个"
    },
    {
      "id": "subtitle_306",
      "start": "00:13:37.233",
      "end": "00:13:40.233",
      "text": "卫星叫做火星侦察轨道器"
    },
    {
      "id": "subtitle_307",
      "start": "00:13:41.000",
      "end": "00:13:43.600",
      "text": "所以毅力可以向卫星发送数据"
    },
    {
      "id": "subtitle_308",
      "start": "00:13:43.933",
      "end": "00:13:46.700",
      "text": "然后将它直接送回地球"
    },
    {
      "id": "subtitle_309",
      "start": "00:13:47.700",
      "end": "00:13:48.800",
      "text": "在地球表面"
    },
    {
      "id": "subtitle_310",
      "start": "00:13:48.800",
      "end": "00:13:51.000",
      "text": "美国航天局使用大量卫星天线"
    },
    {
      "id": "subtitle_311",
      "start": "00:13:51.000",
      "end": "00:13:52.300",
      "text": "与飞船通信"
    },
    {
      "id": "subtitle_312",
      "start": "00:13:52.300",
      "end": "00:13:53.666",
      "text": "整个太阳系"
    },
    {
      "id": "subtitle_313",
      "start": "00:13:53.666",
      "end": "00:13:55.933",
      "text": "这是深空网络的一部分"
    },
    {
      "id": "subtitle_314",
      "start": "00:13:58.633",
      "end": "00:13:59.300",
      "text": "有三个"
    },
    {
      "id": "subtitle_315",
      "start": "00:13:59.300",
      "end": "00:14:01.433",
      "text": "这些卫星天线的主要位置"
    },
    {
      "id": "subtitle_316",
      "start": "00:14:01.433",
      "end": "00:14:02.866",
      "text": "加利福尼亚州博尔德斯通"
    },
    {
      "id": "subtitle_317",
      "start": "00:14:04.333",
      "end": "00:14:05.600",
      "text": "马德里西班牙"
    },
    {
      "id": "subtitle_318",
      "start": "00:14:07.066",
      "end": "00:14:08.800",
      "text": "在澳大利亚堪培拉"
    },
    {
      "id": "subtitle_319",
      "start": "00:14:10.666",
      "end": "00:14:12.400",
      "text": "无论地球面向哪个方向"
    },
    {
      "id": "subtitle_320",
      "start": "00:14:12.400",
      "end": "00:14:15.033",
      "text": "它将永远能够接收来自火星的信号"
    },
    {
      "id": "subtitle_321",
      "start": "00:14:15.033",
      "end": "00:14:17.533",
      "text": "或者太阳系其他遥远的地方"
    },
    {
      "id": "subtitle_322",
      "start": "00:14:19.300",
      "end": "00:14:21.866",
      "text": "毅力号船上有三根天线"
    },
    {
      "id": "subtitle_323",
      "start": "00:14:22.300",
      "end": "00:14:25.633",
      "text": "UHF天线或超高频天线"
    },
    {
      "id": "subtitle_324",
      "start": "00:14:25.633",
      "end": "00:14:27.933",
      "text": "这直接与上面的卫星通信"
    },
    {
      "id": "subtitle_325",
      "start": "00:14:27.933",
      "end": "00:14:30.933",
      "text": "主要用于发送大量信息"
    },
    {
      "id": "subtitle_326",
      "start": "00:14:31.466",
      "end": "00:14:32.900",
      "text": "高增益天线"
    },
    {
      "id": "subtitle_327",
      "start": "00:14:32.900",
      "end": "00:14:35.433",
      "text": "这直接传入和传出地球"
    },
    {
      "id": "subtitle_328",
      "start": "00:14:35.633",
      "end": "00:14:37.233",
      "text": "然后是低增益天线"
    },
    {
      "id": "subtitle_329",
      "start": "00:14:37.233",
      "end": "00:14:39.933",
      "text": "主要用于接收来自地球的数据"
    },
    {
      "id": "subtitle_330",
      "start": "00:14:40.300",
      "end": "00:14:42.866",
      "text": "我们当然不能忘记匠心"
    },
    {
      "id": "subtitle_331",
      "start": "00:14:43.000",
      "end": "00:14:45.133",
      "text": "这是被送往火星的直升机"
    },
    {
      "id": "subtitle_332",
      "start": "00:14:45.133",
      "end": "00:14:46.500",
      "text": "和漫游者一起"
    },
    {
      "id": "subtitle_333",
      "start": "00:14:47.033",
      "end": "00:14:49.433",
      "text": "现在你会把直升机放在漫游者的哪里？"
    },
    {
      "id": "subtitle_334",
      "start": "00:14:49.933",
      "end": "00:14:50.733",
      "text": "仔细看"
    },
    {
      "id": "subtitle_335",
      "start": "00:14:50.733",
      "end": "00:14:54.000",
      "text": "你会在这里看到一个小小的黑色隔间"
    },
    {
      "id": "subtitle_336",
      "start": "00:14:54.300",
      "end": "00:14:55.900",
      "text": "这是存放它的地方"
    },
    {
      "id": "subtitle_337",
      "start": "00:14:56.733",
      "end": "00:14:58.333",
      "text": "着陆后大约两个月"
    },
    {
      "id": "subtitle_338",
      "start": "00:14:58.333",
      "end": "00:15:01.433",
      "text": "直升机最终被部署到地面上"
    },
    {
      "id": "subtitle_339",
      "start": "00:15:01.433",
      "end": "00:15:03.700",
      "text": "这个过程花了大约一周的时间才完成"
    },
    {
      "id": "subtitle_340",
      "start": "00:15:04.333",
      "end": "00:15:07.866",
      "text": "首先把盖子拆了我们把直升机露出来"
    },
    {
      "id": "subtitle_341",
      "start": "00:15:08.433",
      "end": "00:15:11.800",
      "text": "然后打开，小心地折叠起来。"
    },
    {
      "id": "subtitle_342",
      "start": "00:15:12.066",
      "end": "00:15:13.200",
      "text": "腿出来了"
    },
    {
      "id": "subtitle_343",
      "start": "00:15:13.533",
      "end": "00:15:15.433",
      "text": "并落到表面上"
    },
    {
      "id": "subtitle_344",
      "start": "00:15:15.600",
      "end": "00:15:17.066",
      "text": "毅力可以驱赶"
    },
    {
      "id": "subtitle_345",
      "start": "00:15:17.066",
      "end": "00:15:18.933",
      "text": "独创性可以开始吸收"
    },
    {
      "id": "subtitle_346",
      "start": "00:15:18.933",
      "end": "00:15:21.100",
      "text": "太阳能电池板上的阳光"
    },
    {
      "id": "subtitle_347",
      "start": "00:15:22.133",
      "end": "00:15:23.900",
      "text": "直升机有两个旋翼"
    },
    {
      "id": "subtitle_348",
      "start": "00:15:23.900",
      "end": "00:15:26.266",
      "text": "以相反的方向旋转"
    },
    {
      "id": "subtitle_349",
      "start": "00:15:27.500",
      "end": "00:15:28.233",
      "text": "在地球上"
    },
    {
      "id": "subtitle_350",
      "start": "00:15:28.233",
      "end": "00:15:31.100",
      "text": "大多数直升机叶片的转速只有几百"
    },
    {
      "id": "subtitle_351",
      "start": "00:15:31.200",
      "end": "00:15:33.666",
      "text": "每分钟转速"
    },
    {
      "id": "subtitle_352",
      "start": "00:15:34.333",
      "end": "00:15:36.133",
      "text": "让直升机在火星上工作"
    },
    {
      "id": "subtitle_353",
      "start": "00:15:36.133",
      "end": "00:15:38.533",
      "text": "我们必须把刀片转得更快"
    },
    {
      "id": "subtitle_354",
      "start": "00:15:38.733",
      "end": "00:15:41.300",
      "text": "这是因为这里的空气稀薄多了"
    },
    {
      "id": "subtitle_355",
      "start": "00:15:42.000",
      "end": "00:15:43.933",
      "text": "第一次独创性的试飞发生了"
    },
    {
      "id": "subtitle_356",
      "start": "00:15:43.933",
      "end": "00:15:46.433",
      "text": "大约在登陆火星两个月后"
    },
    {
      "id": "subtitle_357",
      "start": "00:15:46.433",
      "end": "00:15:48.900",
      "text": "第一架在另一个星球上飞行的直升机"
    },
    {
      "id": "subtitle_358",
      "start": "00:15:48.900",
      "end": "00:15:51.333",
      "text": "结果是一个巨大的成功"
    },
    {
      "id": "subtitle_359",
      "start": "00:15:51.433",
      "end": "00:15:52.400",
      "text": "从这个视频开始"
    },
    {
      "id": "subtitle_360",
      "start": "00:15:52.400",
      "end": "00:15:54.000",
      "text": "有几个航班"
    },
    {
      "id": "subtitle_361",
      "start": "00:15:54.000",
      "end": "00:15:56.600",
      "text": "独创性仍在运作"
    },
    {
      "id": "subtitle_362",
      "start": "00:15:57.700",
      "end": "00:16:00.300",
      "text": "坚持不懈为未来的任务铺平道路"
    },
    {
      "id": "subtitle_363",
      "start": "00:16:00.300",
      "end": "00:16:00.700",
      "text": "我们将在哪里"
    },
    {
      "id": "subtitle_364",
      "start": "00:16:00.700",
      "end": "00:16:01.133",
      "text": "满怀希望地"
    },
    {
      "id": "subtitle_365",
      "start": "00:16:01.133",
      "end": "00:16:04.233",
      "text": "能够将火星样本送回地球"
    },
    {
      "id": "subtitle_366",
      "start": "00:16:04.633",
      "end": "00:16:07.133",
      "text": "当然，下一个重要里程碑"
    },
    {
      "id": "subtitle_367",
      "start": "00:16:07.266",
      "end": "00:16:09.200",
      "text": "把人类送上火星"
    }
  ]
}
