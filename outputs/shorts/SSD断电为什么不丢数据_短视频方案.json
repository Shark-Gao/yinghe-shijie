  "narration": { "voice": "zh-CN-YunyangNeural", "rate": "+0%", "segments": [
    { "start": "00:00:00.000", "end": "00:00:08.000", "text": "一块两 TB 的 SSD，为什么能把海量文件塞进指甲盖大小的芯片？" },
    { "start": "00:00:08.000", "end": "00:00:16.000", "text": "答案是 3D NAND：它不是把存储单元平铺，而是向上叠了数百层。" },
    { "start": "00:00:16.000", "end": "00:00:25.000", "text": "每个单元靠困住不同数量的电子，记录多个比特。" },
    { "start": "00:00:25.000", "end": "00:00:34.000", "text": "断电以后，电子仍被绝缘层锁在里面，所以文件不会立刻消失。" },
    { "start": "00:00:34.000", "end": "00:00:44.000", "text": "但写入和读取这些电荷，需要复杂的电压步骤。" },
    { "start": "00:00:44.000", "end": "00:00:56.000", "text": "这就是 SSD 容量大又省电，却仍比内存慢得多的根本原因。" }
  ] }
