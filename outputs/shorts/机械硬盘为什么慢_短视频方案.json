  "narration": { "voice": "zh-CN-YunyangNeural", "rate": "+0%", "segments": [
    { "start": "00:00:00.000", "end": "00:00:08.000", "text": "机械硬盘今天还没淘汰，因为它依然能用很低成本塞进海量数据。" },
    { "start": "00:00:08.000", "end": "00:00:17.000", "text": "它把信息写在高速旋转的盘片上，数据分布成数十万条同心轨道。" },
    { "start": "00:00:17.000", "end": "00:00:26.000", "text": "每条轨道又切成扇区，磁头靠磁场变化读出零和一。" },
    { "start": "00:00:26.000", "end": "00:00:36.000", "text": "这种结构能把数万亿比特塞进几张盘片，所以每 GB 的成本非常低。" },
    { "start": "00:00:36.000", "end": "00:00:45.000", "text": "但读取前，磁头必须真的移动到正确轨道，再等盘片转到正确位置。" },
    { "start": "00:00:45.000", "end": "00:00:58.000", "text": "SSD 只等电子通过，硬盘却要等机械运动，这就是两者速度差巨大的根源。" }
  ] }
