  "narration": { "voice": "zh-CN-YunyangNeural", "rate": "+0%", "segments": [
    { "start": "00:00:00.000", "end": "00:00:09.000", "text": "显卡显存不是普通内存的附属品，而是专门喂饱 GPU 的高速仓库。" },
    { "start": "00:00:09.000", "end": "00:00:18.000", "text": "GPU 一次要同时调度上万个核心，真正怕的不是一次读取慢，而是数据通路不够宽。" },
    { "start": "00:00:18.000", "end": "00:00:27.000", "text": "所以显存优先堆的是带宽：更宽的数据总线，加上连续的数据流水线。" },
    { "start": "00:00:27.000", "end": "00:00:36.000", "text": "代价是，它更适合持续吞吐大量数据，不一定追求最低的单次访问延迟。" },
    { "start": "00:00:36.000", "end": "00:00:45.000", "text": "这就是 AI、渲染和大型游戏里，显存容量和带宽都会直接限制性能的原因。" }
  ] }
