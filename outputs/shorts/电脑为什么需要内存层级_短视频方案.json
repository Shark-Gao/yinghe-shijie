  "narration": { "voice": "zh-CN-YunyangNeural", "rate": "+0%", "segments": [
    { "start": "00:00:00.000", "end": "00:00:06.000", "text": "电脑里为什么同时塞着缓存、内存、SSD 和硬盘？" },
    { "start": "00:00:06.000", "end": "00:00:14.000", "text": "因为存得多、读得快、价格低，这三件事没法同时满足。" },
    { "start": "00:00:14.000", "end": "00:00:22.000", "text": "SSD 和硬盘容量大也便宜，访问却慢。CPU 缓存相反，快但贵、容量也小。" },
    { "start": "00:00:22.000", "end": "00:00:31.000", "text": "没有任何一种存储能通吃，所以系统把数据拆到不同层级，再不断把常用内容往前搬。" },
    { "start": "00:00:31.000", "end": "00:00:39.000", "text": "离处理器越近，速度越快，容量和成本却越难兼顾。" },
    { "start": "00:00:39.000", "end": "00:00:46.000", "text": "这就是电脑必须拥有整套内存层级的原因。" }
  ] }
