  "narration": { "voice": "zh-CN-YunyangNeural", "rate": "+0%", "segments": [
    { "start": "00:00:00.000", "end": "00:00:08.000", "text": "电脑内存断电后，为什么会瞬间清空？答案藏在每个 DRAM 单元里。" },
    { "start": "00:00:08.000", "end": "00:00:17.000", "text": "一根内存条上的芯片，被拆成大量独立 Bank，每个 Bank 里又有海量存储单元。" },
    { "start": "00:00:17.000", "end": "00:00:26.000", "text": "最基本的单元只有一个晶体管和一个电容：电容里有没有电，就代表零或一。" },
    { "start": "00:00:26.000", "end": "00:00:36.000", "text": "读写时，CPU 选中一整行单元，再让感测放大器判断每个电容里的电压。" },
    { "start": "00:00:36.000", "end": "00:00:46.000", "text": "这种设计让 DRAM 能做到大容量、高带宽，但每一位都依赖极微弱的电荷。" },
    { "start": "00:00:46.000", "end": "00:00:55.000", "text": "电荷会自然泄漏，所以内存必须不断刷新；一旦断电，数据很快全部消失。" }
  ] }
